---
import { SITE } from '../consts';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import StickyBookingButton from '../components/layout/StickyBookingButton.astro';
import SchemaOrganization from '../components/seo/SchemaOrganization.astro';
import YandexMetrika from '../components/seo/YandexMetrika.astro';
import '../styles/global.css';

const metrikaId: string =
  (import.meta.env.PUBLIC_YANDEX_METRIKA_ID as string | undefined) || '52399276';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  canonical?: string;
}

const {
  title,
  description = SITE.description,
  ogImage = '/og/default.jpg',
  noindex = false,
  canonical,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).href;
const fullTitle =
  title === SITE.name || title.includes(SITE.name) ? title : `${title} — ${SITE.name}`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <title>{fullTitle}</title>
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, SITE.url).href} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, SITE.url).href} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/icon-32.png" />
    <meta name="theme-color" content="#5aaec4" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <SchemaOrganization />
    <slot name="head" />
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <StickyBookingButton />

    <slot name="scripts" />
    {metrikaId && <YandexMetrika id={metrikaId} />}

    <!-- YClients widget (global) -->
    <script async src="https://w196391.yclients.com/widgetJS" charset="UTF-8"></script>
    <script is:inline>
      (function () {
        function initBookingLinks() {
          document
            .querySelectorAll('a[href*="/booking/"], a[href="/booking"]')
            .forEach(function (el) {
              el.classList.add('ms_booking');
              el.addEventListener('click', function (e) {
                e.preventDefault();
              });
            });
        }
        if (document.readyState !== 'loading') {
          initBookingLinks();
        } else {
          document.addEventListener('DOMContentLoaded', initBookingLinks);
        }
      })();
    </script>

    <script is:inline>
      (function () {
        // Scroll Reveal
        const revealObs = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                revealObs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -30px 0px' }
        );
        document.querySelectorAll('[data-reveal]').forEach(function (el) {
          revealObs.observe(el);
        });

        // SVG Wave Draw animation
        document.querySelectorAll('.hero-waves path, .cta-waves path').forEach(function (path) {
          var len = path.getTotalLength();
          path.style.strokeDasharray = len;
          path.style.strokeDashoffset = len;
          path.style.transition = 'stroke-dashoffset 1.6s cubic-bezier(0.4,0,0.2,1)';
        });
        var waveObs = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.querySelectorAll('path').forEach(function (p, i) {
                  setTimeout(function () {
                    p.style.strokeDashoffset = '0';
                  }, i * 350);
                });
                waveObs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.15 }
        );
        document.querySelectorAll('.hero-waves, .cta-waves').forEach(function (el) {
          waveObs.observe(el);
        });
      })();
    </script>
  </body>
</html>
