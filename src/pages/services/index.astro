---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaBreadcrumbs from '../../components/seo/SchemaBreadcrumbs.astro';

const allServices = await getCollection('services');

const womenCandela = allServices.filter(
  (s) => s.data.gender !== 'male' && s.data.technologies.includes('alexandrite')
);
const menCandela = allServices.filter(
  (s) => s.data.gender !== 'female' && s.data.technologies.includes('alexandrite')
);
const womenDiode = allServices.filter(
  (s) => s.data.gender !== 'male' && s.data.technologies.includes('diode')
);
const menDiode = allServices.filter(
  (s) => s.data.gender !== 'female' && s.data.technologies.includes('diode')
);

const categoryLabels: Record<string, string> = {
  basic: 'Основные зоны',
  intimate: 'Интимные зоны',
  face: 'Лицо',
  premium: 'Премиум',
};

const tabs = [
  { id: 'women-candela', label: 'Женские услуги', sub: 'Candela GentlePro', services: womenCandela },
  { id: 'men-candela',   label: 'Мужские услуги', sub: 'Candela GentlePro', services: menCandela },
  { id: 'women-diode',   label: 'Женские услуги', sub: 'InMotion D1',       services: womenDiode },
  { id: 'men-diode',     label: 'Мужские услуги', sub: 'InMotion D1',       services: menDiode },
];
---

<BaseLayout
  title="Услуги лазерной эпиляции"
  description="Полный каталог услуг лазерной эпиляции в Новосибирске. Женские и мужские зоны, александрит Candela GentlePro и диод InMotion D1. Цены, запись онлайн."
>
  <div class="container">
    <SchemaBreadcrumbs items={[{ name: 'Услуги', href: '/services/' }]} />
  </div>

  <section class="services-page">
    <div class="container">
      <div class="page-header">
        <h1 data-reveal>Лазерная эпиляция — все услуги</h1>
        <p data-reveal data-reveal-delay="1">
          Работаем на александритовом лазере Candela GentlePro и диодном InMotion D1.
          Все зоны, любой тип кожи и волос.
        </p>
      </div>

      <!-- 4 Tabs -->
      <div class="services-tabs" role="tablist" aria-label="Выбор категории" data-reveal data-reveal-delay="2">
        {tabs.map((tab, i) => (
          <button
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${tab.id}`}
            id={`tab-${tab.id}`}
            class:list={['stab', { 'stab--active': i === 0 }]}
          >
            <span class="stab-main">{tab.label}</span>
            <span class="stab-sub">{tab.sub}</span>
          </button>
        ))}
      </div>

      <!-- Panels -->
      {tabs.map((tab, i) => (
        <div
          id={`panel-${tab.id}`}
          role="tabpanel"
          aria-labelledby={`tab-${tab.id}`}
          hidden={i !== 0 ? true : undefined}
        >
          {tab.services.length > 0 ? (
            <div class="services-list" data-reveal data-reveal-delay="1">
              {tab.services.map((service) => (
                <a href={`/services/${service.id}/`} class="service-row">
                  <div class="service-row-info">
                    <h3>{service.data.title}</h3>
                    <span class="service-row-category">{categoryLabels[service.data.category]}</span>
                  </div>
                  <div class="service-row-price">
                    <span>от {service.data.price.single.toLocaleString('ru-RU')} ₽</span>
                    {service.data.price.course6 && (
                      <span class="course-price">
                        курс {service.data.price.course6.toLocaleString('ru-RU')} ₽
                      </span>
                    )}
                  </div>
                  <span class="service-row-arrow" aria-hidden="true">→</span>
                </a>
              ))}
            </div>
          ) : (
            <p class="empty-state">Услуги скоро появятся</p>
          )}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
  const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('aria-controls');
      tabs.forEach((t) => {
        t.setAttribute('aria-selected', 'false');
        t.classList.remove('stab--active');
      });
      panels.forEach((p) => p.setAttribute('hidden', ''));
      tab.setAttribute('aria-selected', 'true');
      tab.classList.add('stab--active');
      document.getElementById(target ?? '')?.removeAttribute('hidden');
    });
  });
</script>

<style>
  .services-page { padding: 1rem 0 5rem; }

  .page-header { margin-bottom: 2.5rem; }
  .page-header h1 { margin: 0 0 0.75rem; }
  .page-header p {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 600px;
  }

  /* ── Tabs ── */
  .services-tabs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.625rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 768px) {
    .services-tabs { grid-template-columns: repeat(4, 1fr); }
  }

  .stab {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 0.875rem 1.125rem;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    cursor: pointer;
    text-align: left;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast),
      box-shadow var(--transition-fast);
  }
  .stab:hover {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 4%, white);
  }
  .stab--active {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, white);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 18%, transparent);
  }
  .stab-main {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1;
  }
  .stab--active .stab-main { color: var(--color-primary); }
  .stab-sub {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: 1;
  }

  /* ── Service list ── */
  .services-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .service-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.125rem 1.5rem;
    background: var(--color-bg);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: background var(--transition-fast);
  }
  .service-row:last-child { border-bottom: none; }
  .service-row:hover { background: var(--color-bg-soft); }

  .service-row-info { flex: 1; min-width: 0; }
  .service-row-info h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.25rem;
  }
  .service-row-category { font-size: 0.8125rem; color: var(--color-text-muted); }

  .service-row-price {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.125rem;
    text-align: right;
    flex-shrink: 0;
  }
  .service-row-price span { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); }
  .course-price { font-size: 0.8125rem; color: var(--color-text-muted); font-weight: 400; }

  .service-row-arrow {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform var(--transition-fast), color var(--transition-fast);
  }
  .service-row:hover .service-row-arrow {
    transform: translateX(4px);
    color: var(--color-primary);
  }

  .empty-state {
    padding: 3rem;
    text-align: center;
    color: var(--color-text-muted);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }
</style>
