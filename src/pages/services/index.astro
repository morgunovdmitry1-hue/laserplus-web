---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaBreadcrumbs from '../../components/seo/SchemaBreadcrumbs.astro';

const allServices = await getCollection('services');

const womenCandela = allServices.filter(
  (s) => s.data.gender !== 'male' && s.data.technologies.includes('alexandrite')
);
const menCandela = allServices.filter(
  (s) => s.data.gender !== 'female' && s.data.technologies.includes('alexandrite')
);
const womenDiode = allServices.filter(
  (s) => s.data.gender !== 'male' && s.data.technologies.includes('diode')
);
const menDiode = allServices.filter(
  (s) => s.data.gender !== 'female' && s.data.technologies.includes('diode')
);

const categoryLabels: Record<string, string> = {
  basic: 'Основные зоны',
  intimate: 'Интимные зоны',
  face: 'Лицо',
  premium: 'Премиум',
};

const tabs = [
  { id: 'women-candela', label: 'Женские услуги', sub: 'Candela GentlePro', services: womenCandela, isDiode: false },
  { id: 'men-candela',   label: 'Мужские услуги', sub: 'Candela GentlePro', services: menCandela,   isDiode: false },
  { id: 'women-diode',   label: 'Женские услуги', sub: 'In-Motion D1',       services: womenDiode,   isDiode: true },
  { id: 'men-diode',     label: 'Мужские услуги', sub: 'In-Motion D1',       services: menDiode,     isDiode: true },
];
---

<BaseLayout
  title="Услуги лазерной эпиляции"
  description="Полный каталог услуг лазерной эпиляции в Новосибирске. Женские и мужские зоны, александрит Candela GentlePro и диод In-Motion D1. Цены, запись онлайн."
>
  <div class="container">
    <SchemaBreadcrumbs items={[{ name: 'Услуги', href: '/services/' }]} />
  </div>

  <section class="services-page">
    <div class="container">
      <div class="page-header">
        <h1 data-reveal>Лазерная эпиляция — все услуги</h1>
        <p data-reveal data-reveal-delay="1">
          Работаем на александритовом лазере Candela GentlePro и диодном In-Motion D1.
          Все зоны, любой тип кожи и волос.
        </p>
      </div>

      <!-- 4 Tabs -->
      <div class="services-tabs" role="tablist" aria-label="Выбор категории" data-reveal data-reveal-delay="2">
        {tabs.map((tab, i) => (
          <button
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${tab.id}`}
            id={`tab-${tab.id}`}
            class:list={['stab', { 'stab--active': i === 0 }]}
          >
            <span class="stab-main">{tab.label}</span>
            <span class="stab-sub">{tab.sub}</span>
          </button>
        ))}
      </div>

      <!-- Panels -->
      {tabs.map((tab, i) => (
        <div
          id={`panel-${tab.id}`}
          role="tabpanel"
          aria-labelledby={`tab-${tab.id}`}
          hidden={i !== 0 ? true : undefined}
        >
          {tab.services.length > 0 ? (
            <div class="services-list" data-reveal data-reveal-delay="1">
              <div class="list-header">
                <span class="lh-name">Услуга</span>
                <span class="lh-price">Цена</span>
                <span class="lh-sep">/</span>
                <span class="lh-card">Цена по карте</span>
                <span class="lh-gap"></span>
              </div>
              {tab.services.map((service) => {
                const basePrice = tab.isDiode
                  ? (service.data.price.diode ?? service.data.price.single)
                  : service.data.price.single;
                const cardPrice = Math.round(basePrice * 0.6 / 10) * 10;
                return (
                  <a href={`/services/${service.id}/`} class="service-row">
                    <span class="sr-name">{service.data.title}</span>
                    <span class="sr-price">{basePrice.toLocaleString('ru-RU')} ₽</span>
                    <span class="sr-sep">/</span>
                    <span class="sr-card">{cardPrice.toLocaleString('ru-RU')} ₽</span>
                    <span class="sr-arrow" aria-hidden="true">→</span>
                  </a>
                );
              })}
            </div>
          ) : (
            <p class="empty-state">Услуги скоро появятся</p>
          )}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
  const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('aria-controls');
      tabs.forEach((t) => {
        t.setAttribute('aria-selected', 'false');
        t.classList.remove('stab--active');
      });
      panels.forEach((p) => p.setAttribute('hidden', ''));
      tab.setAttribute('aria-selected', 'true');
      tab.classList.add('stab--active');
      document.getElementById(target ?? '')?.removeAttribute('hidden');
    });
  });
</script>

<style>
  .services-page { padding: 1rem 0 5rem; }

  .page-header { margin-bottom: 2.5rem; }
  .page-header h1 { margin: 0 0 0.75rem; }
  .page-header p {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 600px;
  }

  /* ── Tabs ── */
  .services-tabs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.625rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 768px) {
    .services-tabs { grid-template-columns: repeat(4, 1fr); }
  }

  .stab {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 0.875rem 1.125rem;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 100px;
    cursor: pointer;
    text-align: left;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast),
      box-shadow var(--transition-fast);
  }
  .stab:hover {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 4%, white);
  }
  .stab--active {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, white);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 18%, transparent);
  }
  .stab-main {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1;
  }
  .stab--active .stab-main { color: var(--color-primary); }
  .stab-sub {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: 1;
  }

  /* ── Service list ── */
  .services-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  /* ── Header & rows — одна строка как в прайсе ── */
  .list-header,
  .service-row {
    display: grid;
    grid-template-columns: 1fr 100px 18px 110px 28px;
    align-items: center;
    gap: 0;
    padding: 0.625rem 1.25rem;
  }

  .list-header {
    background: var(--color-bg-soft);
    border-bottom: 2px solid var(--color-border);
  }
  .lh-name, .lh-price, .lh-sep, .lh-card, .lh-gap {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
  }
  .lh-price { text-align: right; }
  .lh-sep   { text-align: center; color: var(--color-border); }
  .lh-card  { text-align: right; color: color-mix(in srgb, var(--color-primary) 75%, black); }

  .service-row {
    background: var(--color-bg);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: background var(--transition-fast);
    padding: 0.875rem 1.25rem;
  }
  .service-row:last-child { border-bottom: none; }
  .service-row:hover { background: var(--color-bg-soft); }

  .sr-name {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.35;
    padding-right: 1rem;
  }
  .sr-price {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text);
    text-align: right;
    white-space: nowrap;
  }
  .sr-sep {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
  }
  .sr-card {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-primary);
    text-align: right;
    white-space: nowrap;
  }
  .sr-arrow {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: right;
    transition: transform var(--transition-fast), color var(--transition-fast);
  }
  .service-row:hover .sr-arrow {
    transform: translateX(3px);
    color: var(--color-primary);
  }

  @media (max-width: 600px) {
    .list-header,
    .service-row {
      grid-template-columns: 1fr 80px 14px 88px 22px;
      padding: 0.75rem 1rem;
    }
    .sr-name { font-size: 0.875rem; }
    .sr-price, .sr-card { font-size: 0.875rem; }
  }

  .empty-state {
    padding: 3rem;
    text-align: center;
    color: var(--color-text-muted);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }
</style>
