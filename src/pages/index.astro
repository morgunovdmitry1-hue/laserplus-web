</style>

<script>
  let activeLaser = 'diode';
  let activeCat = 'body';

  const laserBtns = document.querySelectorAll<HTMLButtonElement>('.ltab');
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.ptab');
  const panels = document.querySelectorAll<HTMLElement>('.price-panel');

  function showPanel() {
    panels.forEach((p) => p.classList.add('price-panel--hidden'));
    document
      .getElementById(`panel-${activeLaser}-${activeCat}`)
      ?.classList.remove('price-panel--hidden');
  }

  laserBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeLaser = btn.dataset.laser!;
      laserBtns.forEach((b) => {
        b.classList.remove('ltab--active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('ltab--active');
      btn.setAttribute('aria-selected', 'true');
      showPanel();
    });
  });

  catBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.cat!;
      catBtns.forEach((b) => {
        b.classList.remove('ptab--active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('ptab--active');
      btn.setAttribute('aria-selected', 'true');
      showPanel();
    });
  });
</script>
