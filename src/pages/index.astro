---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, CLINICS } from '../consts';
import { sanityClient, isSanityConfigured } from '../lib/sanity';
import { getCollection } from 'astro:content';

interface SanityHomePage {
  hero?: { title?: string; titleAccent?: string; ctaPrimary?: string };
  cta?: { button?: string };
}

// Fetch homepage content from Sanity (with fallback)
// eslint-disable-next-line @typescript-eslint/no-unsafe-assignment
const homePageRaw = isSanityConfigured()
  ? await sanityClient.fetch(`*[_type == "homePage"][0]{ hero, stats, cta }`)
  : null;
const homePage = homePageRaw as SanityHomePage | null;

const hero = homePage?.hero;
const stats: { value: string; label: string }[] = [
  { value: '7+', label: 'лет работы' },
  { value: '9 000+', label: 'клиентов' },
  { value: '2', label: 'клиники в городе' },
  { value: 'Большой парк', label: 'оборудования' },
];
const cta = homePage?.cta;

// Services for price list
const allServices = await getCollection('services');
const svcMap = Object.fromEntries(allServices.map((s) => [s.id, s.data]));

const cardPrice = (p: number) => Math.round((p * 0.6) / 10) * 10;

const bodyItems = [
  { id: 'podmyshki', label: 'Подмышки' },
  { id: 'bikini-klassika', label: 'Бикини классика' },
  { id: 'goleni', label: 'Голени' },
  { id: 'byodra', label: 'Бёдра' },
  { id: 'ruki', label: 'Руки полностью' },
  { id: 'nogi-polnostyu', label: 'Ноги полностью' },
];
const faceItems = [
  { id: 'verhnyaya-guba', label: 'Верхняя губа' },
  { id: 'podborodok', label: 'Подбородок' },
  { id: 'shey', label: 'Шея' },
  { id: 'lico-polnostyu', label: 'Лицо полностью' },
];
const menItems = [
  { id: 'men-boroda', label: 'Борода / лицо' },
  { id: 'men-grud', label: 'Грудь' },
  { id: 'men-zhivot', label: 'Живот' },
  { id: 'men-spina', label: 'Спина' },
  { id: 'men-nogi', label: 'Ноги полностью' },
];

const toDiode = ({ id, label }: { id: string; label: string }) => ({
  id,
  label,
  price: svcMap[id]?.price.diode ?? svcMap[id]?.price.single ?? 0,
});
const toAlex = ({ id, label }: { id: string; label: string }) => ({
  id,
  label,
  price: svcMap[id]?.price.single ?? 0,
});

const bodyDiode = bodyItems.map(toDiode);
const faceDiode = faceItems.map(toDiode);
const menDiode = menItems.map(toDiode);
const bodyAlex = bodyItems.map(toAlex);
const faceAlex = faceItems.map(toAlex);
const menAlex = menItems.map(toAlex);
---

<BaseLayout
  title={SITE.name + ' — лазерная эпиляция в Новосибирске'}
  description="Сеть клиник лазерной эпиляции в Новосибирске. Александритовый лазер Candela GentlePro, медицинская лицензия. Записаться онлайн."
>
  <!-- Hero -->
  <section class="hero">
    <svg
      class="hero-waves"
      viewBox="0 0 800 600"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      preserveAspectRatio="xMidYMid slice"
    >
      <path
        d="M -30 120 Q 200 60 480 180 Q 660 240 830 180"
        stroke="var(--color-primary)"
        stroke-opacity="0.08"
        stroke-width="10"
        stroke-linecap="round"
        fill="none"></path>
      <path
        d="M -30 420 Q 250 350 540 460 Q 700 520 830 475"
        stroke="var(--color-primary)"
        stroke-opacity="0.13"
        stroke-width="10"
        stroke-linecap="round"
        fill="none"></path>
    </svg>
    <div class="hero-container container">
      <!-- Left: text -->
      <div class="hero-content" data-reveal>
        <h1 class="hero-title">
          {hero?.title ?? 'Лазерная эпиляция'}<br />
          <span class="hero-title-nowrap hero-title-accent"
            >{hero?.titleAccent ?? 'в Новосибирске'}</span
          >
        </h1>
        <p class="hero-desc">
          Скидка 40% на первый визит. Избавьтесь от нежелательных волос навсегда. Александритовый
          лазер Candela — мировой стандарт качества.<br />Результат с первой процедуры.
        </p>
        <a href="/booking/" class="hero-cta">{hero?.ctaPrimary ?? 'Записаться на приём'}</a>
      </div>

      <!-- Right: bento photo grid -->
      <div class="hero-bento" aria-hidden="true" data-reveal data-reveal-delay="2">
        <!-- Large top card -->
        <div class="hb-top">
          <div class="hb-img hb-img--main"></div>
          <span class="hb-top-pill">Медицинская лицензия</span>
          <a href="/booking/" class="hb-top-btn" tabindex="-1">Записаться</a>
        </div>

        <!-- Bottom row: photo + solid card -->
        <div class="hb-bottom">
          <div class="hb-card hb-card--photo">
            <div class="hb-img hb-img--tech"></div>
            <span class="hb-card-label">Candela GentlePro</span>
          </div>
          <div class="hb-card hb-card--solid">
            <div class="hb-avatars" aria-hidden="true">
              <span class="hb-avatar"></span>
              <span class="hb-avatar"></span>
              <span class="hb-avatar"></span>
            </div>
            <p>Бережный подход и специалисты, которым доверяют клиенты</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust pillars -->
  <section class="trust">
    <div class="container">
      <div class="trust-grid">
        {
          stats.map((s, i) => (
            <div class="trust-item" data-reveal data-reveal-delay={String(i + 1)}>
              <span class="trust-num">{s.value}</span>
              <p class="trust-label">{s.label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Services / Price list -->
  <section class="services-section">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <p class="section-label">Услуги</p>
          <h2>Популярные зоны</h2>
        </div>
        <a href="/services/" class="link-all">Весь прайс-лист</a>
      </div>

      <!-- Controls row: laser + category -->
      <div class="price-controls" data-reveal data-reveal-delay="1">
        <!-- Laser toggle -->
        <div class="laser-tabs" role="tablist" aria-label="Тип лазера">
          <button class="ltab ltab--active" data-laser="diode" role="tab" aria-selected="true">
            <span class="ltab-main">Диодный</span>
            <span class="ltab-sub">In-Motion D1</span>
          </button>
          <button class="ltab" data-laser="alex" role="tab" aria-selected="false">
            <span class="ltab-main">Александрит</span>
            <span class="ltab-sub">Candela GentlePro</span>
          </button>
        </div>
        <!-- Category tabs -->
        <div class="price-tabs" role="tablist" aria-label="Категории услуг">
          <button class="ptab ptab--active" data-cat="body" role="tab" aria-selected="true"
            >Тело</button
          >
          <button class="ptab" data-cat="face" role="tab" aria-selected="false">Лицо</button>
          <button class="ptab" data-cat="men" role="tab" aria-selected="false">Мужское</button>
        </div>
      </div>

      <!-- Panels: diode -->
      {
        [
          { id: 'panel-diode-body', items: bodyDiode },
          { id: 'panel-diode-face', items: faceDiode, hidden: true },
          { id: 'panel-diode-men', items: menDiode, hidden: true },
        ].map(({ id, items, hidden }) => (
          <div
            class:list={['price-panel', { 'price-panel--hidden': hidden }]}
            id={id}
            data-laser="diode"
            data-reveal
            data-reveal-delay="2"
          >
            <div class="pl-header">
              <span class="pl-hname">Услуга</span>
              <span class="pl-hprice">Цена</span>
              <span class="pl-hsep">/</span>
              <span class="pl-hcard">По карте −40%</span>
              <span class="pl-harrow" />
            </div>
            {items.map(({ id: sid, label, price }) => (
              <a href={`/services/${sid}/`} class="price-row">
                <span class="pr-name">{label}</span>
                <span class="pr-price">{price.toLocaleString('ru-RU')} ₽</span>
                <span class="pr-sep">/</span>
                <span class="pr-card">{cardPrice(price).toLocaleString('ru-RU')} ₽</span>
                <span class="pr-arrow" aria-hidden="true">
                  →
                </span>
              </a>
            ))}
          </div>
        ))
      }

      <!-- Panels: alex -->
      {
        [
          { id: 'panel-alex-body', items: bodyAlex },
          { id: 'panel-alex-face', items: faceAlex },
          { id: 'panel-alex-men', items: menAlex },
        ].map(({ id, items }) => (
          <div class="price-panel price-panel--hidden" id={id} data-laser="alex">
            <div class="pl-header">
              <span class="pl-hname">Услуга</span>
              <span class="pl-hprice">Цена</span>
              <span class="pl-hsep">/</span>
              <span class="pl-hcard">По карте −40%</span>
              <span class="pl-harrow" />
            </div>
            {items.map(({ id: sid, label, price }) => (
              <a href={`/services/${sid}/`} class="price-row">
                <span class="pr-name">{label}</span>
                <span class="pr-price">{price.toLocaleString('ru-RU')} ₽</span>
                <span class="pr-sep">/</span>
                <span class="pr-card">{cardPrice(price).toLocaleString('ru-RU')} ₽</span>
                <span class="pr-arrow" aria-hidden="true">
                  →
                </span>
              </a>
            ))}
          </div>
        ))
      }

      <div class="services-footer" data-reveal data-reveal-delay="3">
        <a href="/services/" class="btn-outline">Полный прайс-лист</a>
        <a href="/men/" class="btn-ghost">Для мужчин →</a>
      </div>
    </div>
  </section>

  <!-- Why Laser Plus -->
  <section class="why-section">
    <svg
      class="why-waves"
      viewBox="0 0 1200 500"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      preserveAspectRatio="xMidYMid slice"
    >
      <path
        d="M -50 80 Q 200 20 500 120 Q 750 200 1000 100 Q 1150 50 1280 120"
        stroke="var(--color-primary)"
        stroke-opacity="0.07"
        stroke-width="14"
        stroke-linecap="round"
        fill="none"></path>
      <path
        d="M -50 370 Q 250 300 580 400 Q 820 480 1060 380 Q 1180 330 1280 400"
        stroke="var(--color-primary)"
        stroke-opacity="0.09"
        stroke-width="12"
        stroke-linecap="round"
        fill="none"></path>
    </svg>
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <p class="section-label">Преимущества</p>
          <h2>Почему Laser Plus</h2>
        </div>
        <a href="/about/" class="link-all">Подробнее</a>
      </div>

      <div class="why-bento">
        <!-- Card 1: Candela — wide top-left -->
        <a href="/technology/" class="wc wc-1" data-reveal data-reveal-delay="1">
          <div class="wc-bg wc-bg--candela"></div>
          <div class="wc-overlay"></div>
          <div class="wc-tag">
            Технологии
            <svg
              width="10"
              height="10"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"></path></svg
            >
          </div>
          <div class="wc-body">
            <h3>Александрит Candela GentlePro</h3>
            <p>
              Американский лазер 755 нм с системой охлаждения DCD. Мировой стандарт эффективности.
            </p>
          </div>
        </a>

        <!-- Card 2: Лицензия — tall right -->
        <a href="/about/" class="wc wc-2" data-reveal data-reveal-delay="2">
          <div class="wc-bg wc-bg--license"></div>
          <div class="wc-overlay"></div>
          <div class="wc-tag">
            О клинике
            <svg
              width="10"
              height="10"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"></path></svg
            >
          </div>
          <div class="wc-body">
            <h3>Медицинская лицензия с 2020 года</h3>
            <p>Мастера с медицинским образованием.</p>
          </div>
        </a>

        <!-- Card 3: Без боли — bottom left -->
        <a href="/technology/" class="wc wc-3" data-reveal data-reveal-delay="3">
          <div class="wc-bg wc-bg--comfort"></div>
          <div class="wc-overlay"></div>
          <div class="wc-tag">Комфорт</div>
          <div class="wc-body">
            <h3>Без боли — система DCD</h3>
            <p>Охлаждение кожи перед каждым импульсом лазера.</p>
          </div>
        </a>

        <!-- Card 4: Цены — bottom center -->
        <a href="/prices/" class="wc wc-4" data-reveal data-reveal-delay="4">
          <div class="wc-bg wc-bg--price"></div>
          <div class="wc-overlay"></div>
          <div class="wc-tag">
            Цены
            <svg
              width="10"
              height="10"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"></path></svg
            >
          </div>
          <div class="wc-body">
            <h3>Скидка 40% на первый визит</h3>
            <p>Прозрачные цены без скрытых платежей.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Clinics -->
  <section class="clinics-section">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <p class="section-label">Адреса</p>
          <h2>Наши клиники</h2>
        </div>
      </div>
      <div class="clinics-grid">
        {
          CLINICS.map((clinic, i) => (
            <div class="clinic-card" data-reveal data-reveal-delay={String(i + 1)}>
              <div class="clinic-map">
                <iframe
                  src={`https://yandex.ru/map-widget/v1/?ll=${clinic.geo.lng},${clinic.geo.lat}&z=16&ol=biz&oid=${clinic.yandexOrgId}`}
                  width="100%"
                  height="100%"
                  frameborder="0"
                  loading="lazy"
                  title={`Карта — клиника ${clinic.name}`}
                  allowfullscreen
                />
              </div>
              <div class="clinic-card-top">
                <h3>{clinic.name}</h3>
                <address>
                  <p class="clinic-address">{clinic.address}</p>
                  <p class="clinic-metro">м. {clinic.metro}</p>
                </address>
              </div>
              <div class="clinic-hours">
                {clinic.workingHours.weekdays === clinic.workingHours.weekends ? (
                  <div class="clinic-hour-row">
                    <span class="clinic-hour-days">Ежедневно</span>
                    <span class="clinic-hour-time">{clinic.workingHours.weekdays}</span>
                  </div>
                ) : (
                  <>
                    <div class="clinic-hour-row">
                      <span class="clinic-hour-days">Пн–Пт</span>
                      <span class="clinic-hour-time">{clinic.workingHours.weekdays}</span>
                    </div>
                    <div class="clinic-hour-row">
                      <span class="clinic-hour-days">Сб–Вс</span>
                      <span class="clinic-hour-time">{clinic.workingHours.weekends}</span>
                    </div>
                  </>
                )}
              </div>
              <div class="clinic-card-bottom">
                <a href={`tel:${clinic.phone.replace(/\D/g, '')}`} class="clinic-phone">
                  {clinic.phone}
                </a>
                <a href="/booking/" class="btn-cta btn-cta--sm">
                  Записаться
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-section">
    <div class="cta-inner">
      <!-- Brand wavy lines (from clinic entrance visual identity) -->
      <svg
        class="cta-waves"
        viewBox="0 0 1200 520"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        preserveAspectRatio="xMidYMid slice"
      >
        <!-- Thin diagonal line (top area) -->
        <path
          d="M 320 -10 Q 680 80 1210 200"
          stroke="rgba(255,255,255,0.18)"
          stroke-width="12"
          stroke-linecap="round"
          fill="none"></path>
        <!-- Thick sweeping arc (main brand element) -->
        <path
          d="M -20 310 Q 280 260 560 370 Q 840 480 1210 440"
          stroke="rgba(255,255,255,0.55)"
          stroke-width="22"
          stroke-linecap="round"
          fill="none"></path>
      </svg>

      <!-- Left: text -->
      <div class="cta-content" data-reveal>
        <h2 class="cta-title">
          {'Первое посещение со скидкой 40%'}
        </h2>
        <p class="cta-text">
          Убедитесь в результате лично. Запишитесь на пробную процедуру или <strong
            >бесплатную консультацию&nbsp;специалиста</strong
          >.
        </p>
        <a href="/booking/" class="cta-btn">{cta?.button ?? 'Записаться на приём'} →</a>
      </div>

      <!-- Right: decorative card -->
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--color-bg);
    padding-block: clamp(2.5rem, 7vh, 4.5rem);
    overflow: hidden;
    position: relative;
  }
  .hero-waves {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr 1.15fr;
      gap: 5rem;
      min-height: calc(100vh - 68px - 5rem);
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0 0 1.25rem;
  }
  .hero-title-nowrap {
    white-space: nowrap;
  }
  .hero-title-accent {
    color: var(--color-primary);
  }

  .hero-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 0.875rem 2rem;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: 100px;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: var(--shadow-primary);
    transition:
      background var(--transition-fast),
      box-shadow var(--transition-fast);
  }
  .hero-cta:hover {
    background: var(--color-primary-hover);
    box-shadow: 0 6px 24px rgba(100, 176, 199, 0.45);
    color: #fff;
  }

  /* ── Bento grid ── */
  .hero-bento {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  /* Large top card */
  .hb-top {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    height: 260px;
    background: linear-gradient(135deg, #b8dce8 0%, #7ec5d8 50%, #4fa8bf 100%);
  }
  @media (min-width: 1024px) {
    .hb-top {
      height: 320px;
    }
  }

  .hb-img {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
  }
  .hb-img--main {
    background-image: url('/hero-main.webp');
    background-size: cover;
    background-position: center 25%;
  }

  .hb-top-pill {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    padding: 0.4rem 1rem;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .hb-top-btn {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    padding: 0.4rem 1.125rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .hb-top-btn:hover {
    background: var(--color-primary-hover);
    color: #fff;
  }

  /* Bottom row */
  .hb-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem;
    height: 170px;
  }
  @media (min-width: 1024px) {
    .hb-bottom {
      height: 190px;
    }
  }

  .hb-card {
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
  }

  .hb-card--photo {
    background: linear-gradient(160deg, #d0eaf5 0%, #80c5d8 100%);
  }
  .hb-img--tech {
    width: 100%;
    height: 100%;
    background-image: url('/hero-candela.webp');
    background-size: cover;
    background-position: center 30%;
  }

  .hb-card-label {
    position: absolute;
    bottom: 0.875rem;
    left: 0.875rem;
    padding: 0.35rem 0.875rem;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(6px);
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .hb-card--solid {
    background-image: url('/hero-cups.webp');
    background-size: cover;
    background-position: center 18%;
    padding: 1.125rem 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
  }
  .hb-card--solid::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, transparent 55%);
    pointer-events: none;
  }
  .hb-card--solid p {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    line-height: 1.4;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .hb-avatars {
    display: none;
  }
  .hb-avatar {
    display: none;
  }

  /* ── Trust ── */
  .trust {
    padding-block: 0;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 768px) {
    .trust-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2rem 1.75rem;
    border-right: 1px solid var(--color-border);
  }
  .trust-item:last-child {
    border-right: none;
  }
  .trust-item:nth-child(2n) {
    border-right: none;
  }
  @media (min-width: 768px) {
    .trust-item:nth-child(2n) {
      border-right: 1px solid var(--color-border);
    }
    .trust-item:last-child {
      border-right: none;
    }
  }
  .trust-label--solo {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.2;
    margin: 0;
  }

  .trust-num {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    white-space: nowrap;
    letter-spacing: -0.02em;
  }
  .trust-label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.45;
  }

  /* ── Section commons ── */
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .section-head h2 {
    margin: 0;
  }
  .section-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.375rem;
  }
  .link-all {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--transition-fast);
    padding-bottom: 2px;
    border-bottom: 1px solid currentColor;
  }
  .link-all:hover {
    color: var(--color-primary-dark);
  }

  /* ── Services / Price list ── */
  .services-section {
    padding-block: var(--space-20);
    background: var(--color-bg);
  }

  .price-controls {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  @media (min-width: 640px) {
    .price-controls {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  /* Laser toggle */
  .laser-tabs {
    display: flex;
    gap: 0.5rem;
  }
  .ltab {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    padding: 0.5rem 1rem;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 100px;
    cursor: pointer;
    text-align: left;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast);
  }
  .ltab:hover {
    border-color: var(--color-primary);
  }
  .ltab--active {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, white);
  }
  .ltab-main {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1;
  }
  .ltab--active .ltab-main {
    color: var(--color-primary);
  }
  .ltab-sub {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    line-height: 1;
  }

  .price-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .ptab {
    padding: 0.5rem 1.375rem;
    background: transparent;
    border: 1.5px solid var(--color-border);
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-text-muted);
    cursor: pointer;
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast),
      background var(--transition-fast);
  }
  .ptab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .ptab--active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
    font-weight: 500;
  }
  .ptab--active:hover {
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
    color: #fff;
  }

  .price-panel {
  }
  .price-panel--hidden {
    display: none;
  }

  /* Header row */
  .pl-header {
    display: grid;
    grid-template-columns: 1fr 110px 18px 120px 28px;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 2px solid var(--color-border);
    gap: 0;
  }
  .pl-hname,
  .pl-hprice,
  .pl-hsep,
  .pl-hcard,
  .pl-harrow {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
  }
  .pl-hprice {
    text-align: right;
  }
  .pl-hsep {
    text-align: center;
    color: var(--color-border);
  }
  .pl-hcard {
    text-align: right;
    color: color-mix(in srgb, var(--color-primary) 75%, black);
  }

  .price-row {
    display: grid;
    grid-template-columns: 1fr 110px 18px 120px 28px;
    align-items: center;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: color var(--transition-fast);
    gap: 0;
  }
  .price-row:hover {
    color: var(--color-primary);
  }

  .pr-name {
    font-size: 1rem;
    font-weight: 400;
    color: inherit;
    padding-right: 1rem;
  }
  .pr-price {
    font-size: 1rem;
    font-weight: 700;
    white-space: nowrap;
    text-align: right;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }
  .pr-sep {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
  }
  .pr-card {
    font-size: 1rem;
    font-weight: 700;
    white-space: nowrap;
    text-align: right;
    color: var(--color-primary);
  }
  .pr-arrow {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: right;
    transition:
      transform var(--transition-fast),
      color var(--transition-fast);
  }
  .price-row:hover .pr-arrow {
    transform: translateX(3px);
    color: var(--color-primary);
  }
  .price-row:hover .pr-price {
    color: var(--color-text);
  }

  @media (max-width: 600px) {
    .pl-header,
    .price-row {
      grid-template-columns: 1fr 88px 14px 96px 22px;
    }
    .pr-name {
      font-size: 0.9rem;
    }
    .pr-price,
    .pr-card {
      font-size: 0.9rem;
    }
  }

  .services-footer {
    margin-top: 1.75rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  /* ── Why ── */
  .why-section {
    padding-block: var(--space-20);
    background: var(--color-bg-soft);
    position: relative;
    overflow: hidden;
  }
  .why-waves {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
  .why-section .container {
    position: relative;
    z-index: 1;
  }

  .why-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.625rem;
  }
  @media (min-width: 640px) {
    .why-bento {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 220px 220px;
    }
    .wc-1 {
      grid-column: 1 / 3;
      grid-row: 1;
    }
    .wc-2 {
      display: none;
    }
    .wc-3 {
      grid-column: 1;
      grid-row: 2;
    }
    .wc-4 {
      grid-column: 2;
      grid-row: 2;
    }
  }
  @media (min-width: 1024px) {
    .why-bento {
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: 230px 230px;
    }
    .wc-1 {
      grid-column: 1 / 3;
      grid-row: 1;
    }
    .wc-2 {
      display: flex;
      grid-column: 3;
      grid-row: 1 / 3;
    }
    .wc-3 {
      grid-column: 1;
      grid-row: 2;
    }
    .wc-4 {
      grid-column: 2;
      grid-row: 2;
    }
  }

  .wc {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.25rem;
    text-decoration: none;
    min-height: 200px;
    transition: transform var(--transition-base);
  }
  .wc:hover {
    transform: scale(1.01);
  }

  .wc-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .wc-bg--candela {
    background-image: url('/candela-treatment.webp');
    background-size: cover;
    background-position: center 30%;
  }
  .wc-bg--license {
    background-image: url('/about-sofa.webp');
    background-size: cover;
    background-position: center 20%;
  }
  .wc-bg--comfort {
    background-image: url('/comfort-hands.webp');
    background-size: cover;
    background-position: center 35%;
  }
  .wc-bg--price {
    background-image: url('/price-brochure.webp');
    background-size: cover;
    background-position: center 45%;
  }

  .wc-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.1) 50%,
      transparent 100%
    );
  }

  .wc-tag {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: #fff;
    align-self: flex-start;
    transition: background var(--transition-fast);
  }
  .wc:hover .wc-tag {
    background: rgba(255, 255, 255, 0.28);
  }

  .wc-body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .wc-body h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }
  .wc-body p {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.78);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Clinics ── */
  .clinics-section {
    padding-block: var(--space-20);
    background: var(--color-bg);
  }
  .clinics-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .clinics-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .clinic-card {
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    gap: 0;
    background: var(--color-bg);
    transition:
      box-shadow var(--transition-base),
      border-color var(--transition-base);
    overflow: hidden;
  }
  .clinic-map {
    width: 100%;
    height: 200px;
    flex-shrink: 0;
  }
  .clinic-map iframe {
    width: 100%;
    height: 100%;
    display: block;
    border: none;
  }
  .clinic-card-top,
  .clinic-hours,
  .clinic-card-bottom {
    padding-left: 1.75rem;
    padding-right: 1.75rem;
  }
  .clinic-card-top {
    padding-top: 1.5rem;
    padding-bottom: 0;
  }
  .clinic-card-bottom {
    padding-bottom: 1.75rem;
  }
  .clinic-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }
  .clinic-card-top {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .clinic-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
    color: var(--color-text);
  }
  .clinic-card address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.1875rem;
  }
  .clinic-address {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text);
    margin: 0;
  }
  .clinic-metro {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .clinic-hours {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem 1.75rem;
  }
  .clinic-hour-row {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .clinic-hour-days {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    min-width: 3.5rem;
  }
  .clinic-hour-time {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .clinic-card-links {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.75rem 1.5rem;
    gap: 0.75rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--color-border);
  }
  .clinic-contact-group {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .clinic-contact-label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-right: 0.25rem;
  }
  .clinic-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    color: #fff;
    text-decoration: none;
    transition: opacity var(--transition-fast);
    flex-shrink: 0;
  }
  .clinic-icon-btn:hover {
    opacity: 0.85;
  }
  .clinic-icon-btn--phone {
    background: var(--color-primary);
  }
  .clinic-icon-btn--wa {
    background: var(--color-primary);
  }
  .clinic-2gis-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    background: #4caf1b;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: opacity var(--transition-fast);
    white-space: nowrap;
  }
  .clinic-2gis-btn:hover {
    opacity: 0.85;
    color: #fff;
  }
  .clinic-2gis-sep {
    opacity: 0.5;
    margin: 0 0.125rem;
  }
  .clinic-card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: auto;
  }
  .clinic-phone {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.0625rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color var(--transition-fast);
  }
  .clinic-phone:hover {
    color: var(--color-primary);
  }

  /* ── CTA Section ── */
  .cta-section {
    overflow: hidden;
  }
  .cta-waves {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
  .cta-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: clamp(3rem, 8vw, 5rem) var(--container-padding-mobile);
    background: linear-gradient(130deg, #4a9ab5 0%, #64b0c7 40%, #a8d8e8 75%, #c8ecf5 100%);
    border-radius: var(--radius-xl);
    margin-inline: var(--container-padding-mobile);
    margin-bottom: var(--space-20);
    position: relative;
    overflow: hidden;
    align-items: center;
  }
  @media (min-width: 768px) {
    .cta-inner {
      grid-template-columns: 1fr 1fr;
      margin-inline: var(--container-padding-tablet);
      padding-inline: var(--container-padding-tablet);
    }
  }
  @media (min-width: 1024px) {
    .cta-inner {
      grid-template-columns: 1.1fr 0.9fr;
      margin-inline: var(--container-padding-desktop);
      padding-inline: var(--container-padding-desktop);
    }
  }

  .cta-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
    z-index: 2;
  }
  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .cta-text {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    line-height: 1.65;
    max-width: 380px;
  }
  .cta-text strong {
    color: #fff;
    font-weight: 600;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 0.875rem 2rem;
    background: rgba(255, 255, 255, 0.22);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: 100px;
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: background var(--transition-fast);
    white-space: nowrap;
    backdrop-filter: blur(8px);
  }
  .cta-btn:hover {
    background: rgba(255, 255, 255, 0.35);
    color: #fff;
  }

  /* Decorative card */
  .cta-deco {
    position: relative;
    display: none;
    justify-content: flex-end;
    align-items: flex-end;
    height: 260px;
    z-index: 2;
  }
  @media (min-width: 768px) {
    .cta-deco {
      display: flex;
    }
  }

  .cta-card {
    width: 220px;
    background: #fff;
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    transform: rotate(6deg) translateY(-10px);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .cta-card-sub {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }
  .cta-card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .cta-card-lines {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .cta-card-lines span {
    display: block;
    height: 1.5px;
    background: var(--color-border);
    border-radius: 2px;
  }
  .cta-card-lines span:nth-child(3) {
    width: 65%;
  }
  .cta-card-lines span:nth-child(5) {
    width: 80%;
  }

  .cta-bubble {
    position: absolute;
    top: 0;
    right: 200px;
    background: #fff;
    border-radius: var(--radius-lg);
    padding: 0.875rem 1.125rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    max-width: 180px;
    z-index: 2;
  }
  .cta-bubble::after {
    content: '';
    position: absolute;
    bottom: -8px;
    right: 24px;
    width: 16px;
    height: 16px;
    background: #fff;
    clip-path: polygon(0 0, 100% 0, 50% 100%);
  }
  .cta-bubble p {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Shared buttons ── */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1rem;
    border-radius: 100px;
    text-decoration: none;
    transition:
      background var(--transition-fast),
      box-shadow var(--transition-fast);
    white-space: nowrap;
    box-shadow: var(--shadow-primary);
  }
  .btn-cta:hover {
    background: var(--color-primary-hover);
    color: #fff;
    box-shadow: 0 6px 20px -2px rgb(100 176 199 / 0.45);
  }
  .btn-cta--sm {
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
  }

