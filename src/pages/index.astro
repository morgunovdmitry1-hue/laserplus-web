---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, CLINICS } from '../consts';
import { sanityClient, isSanityConfigured } from '../lib/sanity';

// Fetch homepage content from Sanity (with fallback)
const homePage = isSanityConfigured()
  ? await sanityClient.fetch(`*[_type == "homePage"][0]{ hero, stats, cta }`)
  : null;

const hero = homePage?.hero;
const stats: { value: string; label: string }[] = homePage?.stats ?? [
  { value: '7+',      label: 'лет работы' },
  { value: '5 000+',  label: 'довольных клиентов' },
  { value: '2',       label: 'клиники в городе' },
];
const cta = homePage?.cta;
---

<BaseLayout
  title={SITE.name + ' — лазерная эпиляция в Новосибирске'}
  description="Сеть клиник лазерной эпиляции в Новосибирске. Александритовый лазер Candela GentlePro, медицинская лицензия. Записаться онлайн."
>
  <!-- Hero -->
  <section class="hero">
    <svg class="hero-waves" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
      <path d="M -30 120 Q 200 60 480 180 Q 660 240 830 180" stroke="var(--color-primary)" stroke-opacity="0.08" stroke-width="10" stroke-linecap="round" fill="none"/>
      <path d="M -30 420 Q 250 350 540 460 Q 700 520 830 475" stroke="var(--color-primary)" stroke-opacity="0.13" stroke-width="10" stroke-linecap="round" fill="none"/>
    </svg>
    <div class="container hero-container">

      <!-- Left: text -->
      <div class="hero-content" data-reveal>
        <h1 class="hero-title">
          {hero?.title ?? 'Лазерная'}<br />
          эпиляция<br />
          <span class="hero-title-nowrap hero-title-accent">{hero?.titleAccent ?? 'в Новосибирске'}</span>
        </h1>
        <p class="hero-desc">
          {hero?.description ?? 'Медицинская клиника с александритовым лазером Candela для тех, кто ценит себя.'}
        </p>
        <a href="/booking/" class="hero-cta">{hero?.ctaPrimary ?? 'Записаться на приём'}</a>
      </div>

      <!-- Right: bento photo grid -->
      <div class="hero-bento" aria-hidden="true" data-reveal data-reveal-delay="2">

        <!-- Large top card -->
        <div class="hb-top">
          <div class="hb-img hb-img--main"></div>
          <span class="hb-top-pill">Медицинская лицензия</span>
          <a href="/booking/" class="hb-top-btn" tabindex="-1">Записаться</a>
        </div>

        <!-- Bottom row: photo + solid card -->
        <div class="hb-bottom">
          <div class="hb-card hb-card--photo">
            <div class="hb-img hb-img--tech"></div>
            <span class="hb-card-label">Candela GentlePro</span>
          </div>
          <div class="hb-card hb-card--solid">
            <div class="hb-avatars" aria-hidden="true">
              <span class="hb-avatar"></span>
              <span class="hb-avatar"></span>
              <span class="hb-avatar"></span>
            </div>
            <p>Бережный подход и специалисты, которым доверяют</p>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- Trust pillars -->
  <section class="trust">
    <div class="container">
      <div class="trust-grid">
        {stats.map((s, i) => (
          <div class="trust-item" data-reveal data-reveal-delay={String(i + 1)}>
            <span class="trust-num">{s.value}</span>
            <p class="trust-label">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services / Price list -->
  <section class="services-section">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <p class="section-label">Услуги</p>
          <h2>Популярные зоны</h2>
        </div>
        <a href="/services/" class="link-all">Весь прайс-лист</a>
      </div>

      <!-- Category tabs -->
      <div class="price-tabs" role="tablist" aria-label="Категории услуг" data-reveal data-reveal-delay="1">
        <button class="ptab ptab--active" data-tab="body" role="tab" aria-selected="true" aria-controls="panel-body">Тело</button>
        <button class="ptab" data-tab="face" role="tab" aria-selected="false" aria-controls="panel-face">Лицо</button>
        <button class="ptab" data-tab="men" role="tab" aria-selected="false" aria-controls="panel-men">Мужское</button>
      </div>

      <!-- Panel: Тело -->
      <div class="price-panel" id="panel-body" role="tabpanel" data-reveal data-reveal-delay="2">
        {[
          { title: 'Подмышки',      price: 'от 1 500 ₽', href: '/services/podmyshki/' },
          { title: 'Бикини классика', price: 'от 2 500 ₽', href: '/services/bikini-klassika/' },
          { title: 'Голени',         price: 'от 2 200 ₽', href: '/services/goleni/' },
          { title: 'Бёдра',          price: 'от 2 800 ₽', href: '/services/byodra/' },
          { title: 'Руки полностью', price: 'от 3 500 ₽', href: '/services/ruki/' },
          { title: 'Ноги полностью', price: 'от 5 500 ₽', href: '/services/nogi-polnostyu/' },
        ].map(({ title, price, href }) => (
          <a href={href} class="price-row">
            <span class="pr-name">{title}</span>
            <span class="pr-dots" aria-hidden="true"></span>
            <span class="pr-price">{price}</span>
          </a>
        ))}
      </div>

      <!-- Panel: Лицо -->
      <div class="price-panel price-panel--hidden" id="panel-face" role="tabpanel">
        {[
          { title: 'Верхняя губа',   price: 'от 900 ₽',   href: '/services/verhnyaya-guba/' },
          { title: 'Подбородок',     price: 'от 900 ₽',   href: '/services/podborodok/' },
          { title: 'Шея',            price: 'от 1 500 ₽', href: '/services/shey/' },
          { title: 'Лицо полностью', price: 'от 3 500 ₽', href: '/services/lico-polnostyu/' },
        ].map(({ title, price, href }) => (
          <a href={href} class="price-row">
            <span class="pr-name">{title}</span>
            <span class="pr-dots" aria-hidden="true"></span>
            <span class="pr-price">{price}</span>
          </a>
        ))}
      </div>

      <!-- Panel: Мужское -->
      <div class="price-panel price-panel--hidden" id="panel-men" role="tabpanel">
        {[
          { title: 'Борода',   price: 'от 1 200 ₽', href: '/services/men-boroda/' },
          { title: 'Грудь',    price: 'от 2 200 ₽', href: '/services/men-grud/' },
          { title: 'Живот',    price: 'от 2 000 ₽', href: '/services/men-zhivot/' },
          { title: 'Спина',    price: 'от 3 500 ₽', href: '/services/men-spina/' },
          { title: 'Ноги',     price: 'от 5 500 ₽', href: '/services/men-nogi/' },
        ].map(({ title, price, href }) => (
          <a href={href} class="price-row">
            <span class="pr-name">{title}</span>
            <span class="pr-dots" aria-hidden="true"></span>
            <span class="pr-price">{price}</span>
          </a>
        ))}
      </div>

      <div class="services-footer" data-reveal data-reveal-delay="3">
        <a href="/services/" class="btn-outline">Полный прайс-лист</a>
        <a href="/men/" class="btn-ghost">Для мужчин →</a>
      </div>
    </div>
  </section>

  <!-- Why Laser Plus -->
  <section class="why-section">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <p class="section-label">Преимущества</p>
          <h2>Почему Laser Plus</h2>
        </div>
        <a href="/about/" class="link-all">Подробнее</a>
      </div>

      <div class="why-bento">

        <!-- Card 1: Candela — wide top-left -->
        <a href="/technology/" class="wc wc-1" data-reveal data-reveal-delay="1">
          <div class="wc-bg wc-bg--candela"></div>
          <div class="wc-overlay"></div>
          <div class="wc-tag">
            Технологии
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </div>
          <div class="wc-body">
            <h3>Александрит Candela GentlePro</h3>
            <p>Американский лазер 755 нм с системой охлаждения DCD. Мировой стандарт эффективности.</p>
          </div>
        </a>

        <!-- Card 2: Лицензия — tall right -->
        <a href="/about/" class="wc wc-2" data-reveal data-reveal-delay="2">
          <div class="wc-bg wc-bg--license"></div>
          <div class="wc-overlay"></div>
          <div class="wc-tag">
            О клинике
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </div>
          <div class="wc-body">
            <h3>Медицинская лицензия с 2017</h3>
            <p>Только лазерная эпиляция. 7 сертифицированных специалистов.</p>
          </div>
        </a>

        <!-- Card 3: Без боли — bottom left -->
        <a href="/technology/" class="wc wc-3" data-reveal data-reveal-delay="3">
          <div class="wc-bg wc-bg--comfort"></div>
          <div class="wc-overlay"></div>
          <div class="wc-tag">Комфорт</div>
          <div class="wc-body">
            <h3>Без боли — система DCD</h3>
            <p>Охлаждение кожи перед каждым импульсом лазера.</p>
          </div>
        </a>

        <!-- Card 4: Цены — bottom center -->
        <a href="/prices/" class="wc wc-4" data-reveal data-reveal-delay="4">
          <div class="wc-bg wc-bg--price"></div>
          <div class="wc-overlay"></div>
          <div class="wc-tag">
            Цены
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </div>
          <div class="wc-body">
            <h3>Пакеты нескольких зон</h3>
            <p>Скидка до 24%. Прозрачные цены без скрытых платежей.</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Clinics -->
  <section class="clinics-section">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <p class="section-label">Адреса</p>
          <h2>Наши клиники</h2>
        </div>
      </div>
      <div class="clinics-grid">
        {CLINICS.map((clinic, i) => (
          <div class="clinic-card" data-reveal data-reveal-delay={String(i + 1)}>
            <div class="clinic-card-top">
              <h3>{clinic.name}</h3>
              <address>
                <p class="clinic-address">{clinic.address}</p>
                <p class="clinic-metro">м. {clinic.metro}</p>
              </address>
            </div>
            <div class="clinic-hours">
              <div class="clinic-hour-row">
                <span class="clinic-hour-days">Пн–Пт</span>
                <span class="clinic-hour-time">{clinic.workingHours.weekdays}</span>
              </div>
              <div class="clinic-hour-row">
                <span class="clinic-hour-days">Сб–Вс</span>
                <span class="clinic-hour-time">{clinic.workingHours.weekends}</span>
              </div>
            </div>
            <div class="clinic-card-bottom">
              <a href={`tel:${clinic.phone.replace(/\D/g, '')}`} class="clinic-phone">
                {clinic.phone}
              </a>
              <a href="/booking/" class="btn-cta btn-cta--sm">Записаться</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-section">
    <div class="cta-inner">

      <!-- Brand wavy lines (from clinic entrance visual identity) -->
      <svg class="cta-waves" viewBox="0 0 1200 520" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
        <!-- Thin diagonal line (top area) -->
        <path d="M 320 -10 Q 680 80 1210 200" stroke="rgba(255,255,255,0.18)" stroke-width="12" stroke-linecap="round" fill="none"/>
        <!-- Thick sweeping arc (main brand element) -->
        <path d="M -20 310 Q 280 260 560 370 Q 840 480 1210 440" stroke="rgba(255,255,255,0.55)" stroke-width="22" stroke-linecap="round" fill="none"/>
      </svg>

      <!-- Left: text -->
      <div class="cta-content" data-reveal>
        <h2 class="cta-title">
          {cta?.title ?? <>начни свой путь<br />к гладкой коже<br />с бесплатной консультации.</>}
        </h2>
        <p class="cta-text">
          {cta?.text ?? <>Запишитесь на <strong>бесплатную консультацию</strong> и получите индивидуальный план процедур от&nbsp;специалиста.</>}
        </p>
        <a href="/booking/" class="cta-btn">{cta?.button ?? 'Записаться на приём'} →</a>
      </div>

      <!-- Right: decorative card -->
      <div class="cta-deco" aria-hidden="true" data-reveal data-reveal-delay="2">
        <div class="cta-bubble">
          <p>Почувствуйте заботу<br />и профессионализм<br />с первой процедуры!</p>
        </div>
        <div class="cta-card">
          <p class="cta-card-sub">Laser Plus</p>
          <p class="cta-card-title">план процедур</p>
          <div class="cta-card-lines">
            <span></span><span></span><span></span>
            <span></span><span></span><span></span>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--color-bg);
    padding-block: clamp(2.5rem, 7vh, 4.5rem);
    overflow: hidden;
    position: relative;
  }
  .hero-waves {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr 1.15fr;
      gap: 5rem;
      min-height: calc(100vh - 68px - 5rem);
    }
  }

  .hero-content { display: flex; flex-direction: column; }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0 0 1.25rem;
  }
  .hero-title-nowrap { white-space: nowrap; }
  .hero-title-accent { color: var(--color-primary); }

  .hero-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 0.875rem 2rem;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: 100px;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: var(--shadow-primary);
    transition: background var(--transition-fast), box-shadow var(--transition-fast);
  }
  .hero-cta:hover {
    background: var(--color-primary-hover);
    box-shadow: 0 6px 24px rgba(100, 176, 199, 0.45);
    color: #fff;
  }

  /* ── Bento grid ── */
  .hero-bento {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  /* Large top card */
  .hb-top {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    height: 260px;
    background: linear-gradient(135deg, #b8dce8 0%, #7ec5d8 50%, #4fa8bf 100%);
  }
  @media (min-width: 1024px) { .hb-top { height: 320px; } }

  .hb-img {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
  }
  .hb-img--main {
    background: linear-gradient(135deg, #b8dce8 0%, #7ec5d8 50%, #4fa8bf 100%);
  }

  .hb-top-pill {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    padding: 0.4rem 1rem;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .hb-top-btn {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    padding: 0.4rem 1.125rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .hb-top-btn:hover { background: var(--color-primary-hover); color: #fff; }

  /* Bottom row */
  .hb-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem;
    height: 170px;
  }
  @media (min-width: 1024px) { .hb-bottom { height: 190px; } }

  .hb-card {
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
  }

  .hb-card--photo {
    background: linear-gradient(160deg, #d0eaf5 0%, #80c5d8 100%);
  }
  .hb-img--tech {
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, #d0eaf5 0%, #80c5d8 100%);
  }

  .hb-card-label {
    position: absolute;
    bottom: 0.875rem;
    left: 0.875rem;
    padding: 0.35rem 0.875rem;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(6px);
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .hb-card--solid {
    background: var(--color-primary);
    padding: 1.125rem 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .hb-card--solid p {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    line-height: 1.4;
    margin: 0;
  }

  .hb-avatars {
    display: flex;
    margin-bottom: 0.5rem;
  }
  .hb-avatar {
    display: block;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    border: 2px solid rgba(255, 255, 255, 0.6);
    margin-right: -6px;
    flex-shrink: 0;
  }

  /* ── Trust ── */
  .trust {
    padding-block: 0;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  @media (min-width: 768px) { .trust-grid { grid-template-columns: repeat(3, 1fr); } }

  .trust-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2rem 1.75rem;
    border-right: 1px solid var(--color-border);
  }
  .trust-item:last-child { border-right: none; }

  .trust-num {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .trust-label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.45;
  }

  /* ── Section commons ── */
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .section-head h2 { margin: 0; }
  .section-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.375rem;
  }
  .link-all {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--transition-fast);
    padding-bottom: 2px;
    border-bottom: 1px solid currentColor;
  }
  .link-all:hover { color: var(--color-primary-dark); }

  /* ── Services / Price list ── */
  .services-section {
    padding-block: var(--space-20);
    background: var(--color-bg);
  }

  .price-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }
  .ptab {
    padding: 0.5rem 1.375rem;
    background: transparent;
    border: 1.5px solid var(--color-border);
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
  }
  .ptab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .ptab--active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
    font-weight: 500;
  }
  .ptab--active:hover {
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
    color: #fff;
  }

  .price-panel { }
  .price-panel--hidden { display: none; }

  .price-row {
    display: flex;
