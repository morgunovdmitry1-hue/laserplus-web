<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.ptab');
  const panels = document.querySelectorAll<HTMLElement>('.price-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach((t) => { t.classList.remove('ptab--active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach((p) => p.classList.add('price-panel--hidden'));
      tab.classList.add('ptab--active');
      tab.setAttribute('aria-selected', 'true');
      document.getElementById(`panel-${target}`)?.classList.remove('price-panel--hidden');
    });
  });
</script>
