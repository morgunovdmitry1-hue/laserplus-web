---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaBreadcrumbs from '../components/seo/SchemaBreadcrumbs.astro';
import { CLINICS } from '../consts';
---

<BaseLayout
  title="О клинике Laser Plus — медицинская лицензия, оборудование, команда"
  description="Laser Plus — сеть клиник лазерной эпиляции в Новосибирске с 2018 года. Медицинская лицензия, Candela GentlePro, 7 опытных специалистов. Два адреса."
>
  <div class="container">
    <SchemaBreadcrumbs items={[{ name: 'О клинике', href: '/about/' }]} />
  </div>

  <!-- Hero -->
  <section class="about-hero">
    <svg
      class="about-hero-waves"
      viewBox="0 0 1200 400"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      preserveAspectRatio="xMidYMid slice"
    >
      <path
        d="M -50 80 Q 200 20 500 120 Q 750 200 1000 100 Q 1150 50 1280 120"
        stroke="var(--color-primary)"
        stroke-opacity="0.07"
        stroke-width="10"
        stroke-linecap="round"
        fill="none"></path>
      <path
        d="M -50 320 Q 250 260 580 340 Q 820 400 1060 310 Q 1180 270 1280 340"
        stroke="var(--color-primary)"
        stroke-opacity="0.1"
        stroke-width="10"
        stroke-linecap="round"
        fill="none"></path>
    </svg>
    <div class="container">
      <div class="about-hero-inner">
        <div class="about-hero-content">
          <div class="about-badge">Работаем с 2018 года в Новосибирске</div>
          <h1 data-reveal>Клиника<br /><span class="accent">Laser Plus</span></h1>
          <p data-reveal data-reveal-delay="1">
            Специализированная сеть клиник лазерной эпиляции. Мы не делаем маникюр, массаж и «всё
            подряд» — только лазерная эпиляция, только профессиональное оборудование, только
            результат.
          </p>
        </div>
        <div class="about-hero-stats">
          <div class="big-stat" data-reveal data-reveal-delay="1">
            <strong>8+</strong>
            <span>лет опыта</span>
          </div>
          <div class="big-stat" data-reveal data-reveal-delay="2">
            <strong>9 000+</strong>
            <span>клиентов</span>
          </div>
          <div class="big-stat" data-reveal data-reveal-delay="3">
            <strong>2</strong>
            <span>клиники</span>
          </div>
          <div class="big-stat" data-reveal data-reveal-delay="4">
            <strong>Большой парк</strong>
            <span>оборудования</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- License & positioning -->
  <section class="about-license">
    <div class="container">
      <div class="license-grid">
        <div class="license-main">
          <h2 data-reveal>Медицинская лицензия</h2>
          <p data-reveal data-reveal-delay="1">
            Laser Plus работает по медицинской лицензии. Лазерная эпиляция — медицинская процедура,
            и именно так мы к ней относимся.
          </p>
          <p data-reveal data-reveal-delay="2">
            Лицензия означает: проверенное оборудование, сертифицированные специалисты, соблюдение
            санитарных норм и полная юридическая ответственность за результат.
          </p>
          <div class="license-detail" data-reveal data-reveal-delay="3">
            <a href="/license/" class="license-badge-block">
              <div class="badge-icon" aria-hidden="true">
                <svg
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  ></path>
                </svg>
              </div>
              <div>
                <strong>Лицензия Министерства здравоохранения</strong>
                <p>Новосибирская область — посмотреть документы</p>
              </div>
            </a>
          </div>
        </div>
        <div class="license-side">
          <div class="positioning-card" data-reveal data-reveal-delay="2">
            <h3>Почему только лазер?</h3>
            <ul>
              <li>Узкая специализация — это глубокая экспертиза</li>
              <li>Мастера работают только с лазерным оборудованием</li>
              <li>Протоколы отработаны до деталей за 7 лет</li>
              <li>Нет рассеивания — только лучший результат в эпиляции</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Equipment -->
  <section class="about-equipment">
    <div class="container">
      <h2 data-reveal>Оборудование</h2>
      <p class="section-desc" data-reveal data-reveal-delay="1">
        Два лазерных аппарата — для разных типов кожи и задач. Подбор технологии происходит на
        консультации.
      </p>
      <div class="aeq-grid">
        <!-- Candela -->
        <div class="aeq-card" data-reveal data-reveal-delay="1">
          <div class="aeq-photo aeq-photo--candela">
            <div class="aeq-photo-title">
              <p class="aeq-type">Александритовый лазер</p>
              <h3 class="aeq-name">Candela GentlePro</h3>
              <p class="aeq-wave">Топ премиум</p>
            </div>
          </div>
          <div class="aeq-desc-wrap">
            <p class="aeq-desc">
              Мы работаем на оригинальном лазере Candela (США) — это золотой стандарт в мире
              лазерной эпиляции. Не корейский аналог, не китайская копия — а оригинал, на котором
              обучают специалистов по всему миру.
            </p>
            <p class="aeq-desc">
              Ключевое отличие — система охлаждения. Мы используем медицинский фреон, который
              охлаждает кожу до −30°C прямо в момент вспышки. Именно это делает процедуру комфортной
              и безопасной.
            </p>
          </div>
          <div class="aeq-sections">
            <div class="aeq-section">
              <h4>Показания</h4>
              <ul>
                <li>Светлая и смуглая кожа (фототипы I–IV)</li>
                <li>Светлые, тёмные и коричневые волосы</li>
                <li>Без загара (прошло более 2 недель)</li>
                <li>Все зоны тела и лица</li>
              </ul>
            </div>
            <div class="aeq-section">
              <h4>Преимущества</h4>
              <ul>
                <li>Наивысшая эффективность даже на светлых волосах</li>
                <li>Минимальный дискомфорт благодаря охлаждению фреоном</li>
                <li>Быстрая обработка больших зон</li>
                <li>Доказанная клиническая эффективность</li>
              </ul>
            </div>
          </div>
          <div class="aeq-stats">
            <div class="aeq-stat">
              <strong>95%</strong><span>нежелательных волосков убирает за один курс</span>
            </div>
            <div class="aeq-stat"><strong>5–7</strong><span>процедур стандартный курс</span></div>
          </div>
        </div>

        <!-- In-Motion D1 -->
        <div class="aeq-card" data-reveal data-reveal-delay="2">
          <div class="aeq-photo aeq-photo--diode">
            <div class="aeq-photo-title">
              <p class="aeq-type">Диодный лазер</p>
              <h3 class="aeq-name">In-Motion D1</h3>
              <p class="aeq-wave">Проверенная классика</p>
            </div>
          </div>
          <div class="aeq-desc-wrap">
            <p class="aeq-desc">
              Диодный лазер IN-MOTION D1 — универсальный диодный лазер. Подходит для начала курса
              лазерной эпиляции. Технология скользящего импульса — движения по коже непрерывно, что
              позволяет работать со смуглой кожей и в период лёгкого загара.
            </p>
          </div>
          <div class="aeq-sections">
            <div class="aeq-section">
              <h4>Показания</h4>
              <ul>
                <li>Смуглая и тёмная кожа (фототипы IV–VI)</li>
                <li>Период лёгкого загара</li>
                <li>Светлые, русые и тёмные волосы</li>
                <li>Чувствительная кожа</li>
              </ul>
            </div>
            <div class="aeq-section">
              <h4>Преимущества</h4>
              <ul>
                <li>Работает с загорелой кожей</li>
                <li>Щадящий режим для чувствительных зон</li>
                <li>Подходит для тёмных фототипов</li>
                <li>Непрерывная система охлаждения</li>
              </ul>
            </div>
          </div>
          <div class="aeq-stats">
            <div class="aeq-stat"><strong>8–10</strong><span>процедур стандартный курс</span></div>
            <div class="aeq-stat">
              <strong>1</strong><span>заметный результат после первого сеанса</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="about-team">
    <div class="container">
      <h2 data-reveal>Наши мастера</h2>
      <p class="section-desc" data-reveal data-reveal-delay="1">
        Каждый прошёл обучение и имеет опыт работы на оборудовании Candela и IN-MOTION D1 не менее
        3х лет.
      </p>
      <p class="section-desc" data-reveal data-reveal-delay="2">
        Каждый мастер имеет медицинское образование и регулярно проходит аттестацию по повышению
        квалификации.
      </p>
      <div class="team-qualities">
        {
          [
            {
              title: 'Сертификация',
              desc: 'Все мастера имеют медицинское образование и сертификат о прохождении обучения для работы на оборудовании.',
            },
            {
              title: 'Обучение',
              desc: 'Регулярное обучение: обновления протоколов, новые зоны и особые случаи работы с кожей.',
            },
            {
              title: 'Консультация',
              desc: 'Перед каждым курсом — бесплатная консультация: определение фототипа, подбор оборудования и плана процедур.',
            },
          ].map(({ title, desc }, i) => (
            <div class="team-quality" data-reveal data-reveal-delay={String(i + 1)}>
              <h4>{title}</h4>
              <p>{desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Clinics -->
  <section class="about-clinics">
    <div class="container">
      <h2 data-reveal>Наши адреса</h2>
      <div class="ac-grid">
        {
          CLINICS.map((clinic, i) => (
            <div class="ac-card" data-reveal data-reveal-delay={String(i + 1)}>
              <div class="ac-map">
                <iframe
                  src={`https://yandex.ru/map-widget/v1/?ll=${clinic.geo.lng},${clinic.geo.lat}&z=16&ol=biz&oid=${clinic.yandexOrgId}`}
                  width="100%"
                  height="100%"
                  frameborder="0"
                  loading="lazy"
                  title={`Карта — клиника ${clinic.name}`}
                  allowfullscreen
                />
              </div>
              <div class="ac-card-top">
                <h3>{clinic.name}</h3>
                <address>
                  <p class="ac-address">{clinic.address}</p>
                  <p class="ac-metro">м. {clinic.metro}</p>
                </address>
              </div>
              <div class="ac-hours">
                {clinic.workingHours.weekdays === clinic.workingHours.weekends ? (
                  <div class="ac-hour-row">
                    <span class="ac-hour-days">Ежедневно</span>
                    <span class="ac-hour-time">{clinic.workingHours.weekdays}</span>
                  </div>
                ) : (
                  <>
                    <div class="ac-hour-row">
                      <span class="ac-hour-days">Пн–Пт</span>
                      <span class="ac-hour-time">{clinic.workingHours.weekdays}</span>
                    </div>
                    <div class="ac-hour-row">
                      <span class="ac-hour-days">Сб–Вс</span>
                      <span class="ac-hour-time">{clinic.workingHours.weekends}</span>
                    </div>
                  </>
                )}
              </div>
              <div class="ac-card-bottom">
                <a href={`tel:${clinic.phone.replace(/\D/g, '')}`} class="ac-phone">
                  {clinic.phone}
                </a>
                <a href="/booking/" class="btn-primary">
                  Записаться
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="about-values">
    <div class="container">
      <h2 data-reveal>Наши принципы</h2>
      <div class="values-grid">
        {
          [
            {
              title: 'Честность',
              desc: 'Не обещаем результата, которого нет. Если лазер в Вашем случае не даст эффекта — скажем об этом на консультации.',
            },
            {
              title: 'Безопасность',
              desc: 'Медицинская лицензия — не формальность. Это обязательства, стандарты и полная ответственность за каждый результат.',
            },
            {
              title: 'Долгосрочный результат',
              desc: 'Курс, а не разовые процедуры. Мы заинтересованы в том, чтобы Вы получили наилучший результат.',
            },
          ].map(({ title, desc }, i) => (
            <div class="value-item" data-reveal data-reveal-delay={String(i + 1)}>
              <h4>{title}</h4>
              <p>{desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="about-cta">
    <div class="container">
      <div class="cta-box">
        <div data-reveal>
          <h2>Первая консультация бесплатно</h2>
          <p>Специалист определит фототип кожи, подберёт оборудование и ответит на все вопросы.</p>
        </div>
        <a href="/booking/" class="btn-primary" data-reveal data-reveal-delay="2"
          >Записаться онлайн</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding: 2.5rem 0 4rem;
    background: var(--color-bg-soft);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }
  .about-hero-waves {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .about-hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
  }
  @media (min-width: 1024px) {
    .about-hero-inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-badge {
    display: inline-flex;
    padding: 0.3rem 0.875rem;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 100px;
    margin-bottom: 1rem;
    letter-spacing: 0.03em;
  }
  .about-hero-content h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 1.25rem;
  }
  .accent {
    color: var(--color-primary);
  }
  .about-hero-content > p {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
    max-width: 480px;
  }

  .about-hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .big-stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .big-stat strong {
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.15;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }
  .big-stat span {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* License */
  .about-license {
    padding: 3.5rem 0;
  }
  .license-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 1024px) {
    .license-grid {
      grid-template-columns: 3fr 2fr;
    }
  }

  .about-license h2 {
    margin: 0 0 1.25rem;
  }
  .about-license p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0 0 1rem;
  }
  .about-license p:last-of-type {
    margin-bottom: 1.5rem;
  }

  .license-detail {
    margin-top: 0.5rem;
  }
  .license-badge-block {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: color-mix(in srgb, var(--color-primary) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast);
  }
  .license-badge-block:hover {
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
  }
  .badge-icon {
    width: 48px;
    height: 48px;
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .license-badge-block strong {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text);
    display: block;
  }
  .license-badge-block p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0.25rem 0 0;
  }

  .positioning-card {
    padding: 2rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    height: 100%;
  }
  .positioning-card h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    margin: 0 0 1.25rem;
  }
  .positioning-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .positioning-card li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .positioning-card li::before {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
    margin-top: 0.45em;
  }

  /* Equipment */
  .about-equipment {
    padding: 3.5rem 0;
    background: var(--color-bg-soft);
    border-top: 1px solid var(--color-border);
  }
  .about-equipment h2 {
    margin: 0 0 0.75rem;
  }
  .section-desc {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 0 2.5rem;
    line-height: 1.6;
  }

  .aeq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 1024px) {
    .aeq-grid {
      grid-template-columns: 1fr 1fr;
      column-gap: 1.5rem;
      row-gap: 0;
    }
    .aeq-card:nth-child(1) {
      grid-column: 1;
      grid-row: 1 / 5;
      display: grid;
      grid-template-rows: subgrid;
    }
    .aeq-card:nth-child(2) {
      grid-column: 2;
      grid-row: 1 / 5;
      display: grid;
      grid-template-rows: subgrid;
    }
  }

  .aeq-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .aeq-photo {
    position: relative;
    height: 260px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.75rem 2rem;
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .aeq-photo {
      height: 300px;
    }
  }

  .aeq-photo--candela {
    background:
      linear-gradient(
        to top,
        rgba(13, 35, 51, 0.72) 0%,
        rgba(13, 35, 51, 0.1) 60%,
        transparent 100%
      ),
      url('/candela-procedure.webp') center 68% / cover no-repeat;
  }
  .aeq-photo--diode {
    background:
      linear-gradient(
        to top,
        rgba(13, 35, 51, 0.65) 0%,
        rgba(13, 35, 51, 0.1) 50%,
        transparent 100%
      ),
      url('/inmotion-procedure.webp') center 40% / cover no-repeat;
  }

  .aeq-photo-title {
    position: relative;
