---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaBreadcrumbs from '../components/seo/SchemaBreadcrumbs.astro';
import { CLINICS } from '../consts';
---

<BaseLayout
  title="О клинике Laser Plus — медицинская лицензия, оборудование, команда"
  description="Laser Plus — сеть клиник лазерной эпиляции в Новосибирске с 2017 года. Медицинская лицензия, Candela GentlePro, 7 опытных специалистов. Два адреса."
>
  <div class="container">
    <SchemaBreadcrumbs items={[{ name: 'О клинике', href: '/about/' }]} />
  </div>

  <!-- Hero -->
  <section class="about-hero">
    <div class="container">
      <div class="about-hero-inner">
        <div class="about-hero-content">
          <div class="about-badge">С 2017 года в Новосибирске</div>
          <h1 data-reveal>Клиника<br /><span class="accent">Laser Plus</span></h1>
          <p data-reveal data-reveal-delay="1">
            Специализированная сеть клиник лазерной эпиляции. Мы не делаем маникюр, массаж и «всё подряд» —
            только лазерная эпиляция, только профессиональное оборудование, только результат.
          </p>
        </div>
        <div class="about-hero-stats">
          <div class="big-stat" data-reveal data-reveal-delay="1">
            <strong>7+</strong>
            <span>лет опыта</span>
          </div>
          <div class="big-stat" data-reveal data-reveal-delay="2">
            <strong>5 000+</strong>
            <span>клиентов</span>
          </div>
          <div class="big-stat" data-reveal data-reveal-delay="3">
            <strong>2</strong>
            <span>клиники</span>
          </div>
          <div class="big-stat" data-reveal data-reveal-delay="4">
            <strong>7</strong>
            <span>специалистов</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- License & positioning -->
  <section class="about-license">
    <div class="container">
      <div class="license-grid">
        <div class="license-main">
          <h2 data-reveal>Медицинская лицензия</h2>
          <p data-reveal data-reveal-delay="1">
            Laser Plus работает по медицинской лицензии на осуществление медицинской деятельности.
            Лазерная эпиляция — медицинская процедура, и именно так мы к ней относимся.
          </p>
          <p data-reveal data-reveal-delay="2">
            Лицензия означает: проверенное оборудование, сертифицированные специалисты,
            соблюдение санитарных норм и полная юридическая ответственность за результат.
          </p>
          <div class="license-detail" data-reveal data-reveal-delay="3">
            <div class="license-badge-block">
              <div class="badge-icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <div>
                <strong>Лицензия Министерства здравоохранения</strong>
                <p>Новосибирская область</p>
              </div>
            </div>
          </div>
        </div>
        <div class="license-side">
          <div class="positioning-card" data-reveal data-reveal-delay="2">
            <h3>Почему только лазер?</h3>
            <ul>
              <li>Узкая специализация — это глубокая экспертиза</li>
              <li>Мастера работают только с лазерным оборудованием</li>
              <li>Протоколы отработаны до деталей за 7 лет</li>
              <li>Нет рассеивания — только лучший результат в эпиляции</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Equipment -->
  <section class="about-equipment">
    <div class="container">
      <h2 data-reveal>Оборудование</h2>
      <p class="section-desc" data-reveal data-reveal-delay="1">
        Два лазерных аппарата — для разных типов кожи и задач.
        Подбор технологии происходит на консультации.
      </p>
      <div class="equipment-grid">
        <div class="equipment-card equipment-card--primary" data-reveal data-reveal-delay="1">
          <div class="equip-header">
            <div class="equip-label">Основной аппарат</div>
            <h3>Candela GentlePro</h3>
            <div class="equip-type">Александритовый лазер · 755 нм</div>
          </div>
          <div class="equip-body">
            <p>
              Американский лазер класса «золотой стандарт» — именно такой стоит в ведущих клиниках мира.
              Система охлаждения DCD защищает кожу перед каждым импульсом.
            </p>
            <ul>
              <li>Наивысшая эффективность на тёмных волосах</li>
              <li>Кожа I–IV фототипа без загара</li>
              <li>Минимальный дискомфорт</li>
            </ul>
            <a href="/technology/" class="equip-link">Подробнее о технологии →</a>
          </div>
        </div>
        <div class="equipment-card" data-reveal data-reveal-delay="2">
          <div class="equip-header equip-header--alt">
            <div class="equip-label">Дополнительный аппарат</div>
            <h3>IN-MOTION D1</h3>
            <div class="equip-type">Диодный лазер · 810 нм</div>
          </div>
          <div class="equip-body">
            <p>
              Диодный лазер со скользящим импульсом. Идеально для смуглой и тёмной кожи,
              периода лёгкого загара и чувствительных зон.
            </p>
            <ul>
              <li>Фототипы IV–VI</li>
              <li>Работает с загорелой кожей</li>
              <li>Щадящий режим</li>
            </ul>
            <a href="/technology/" class="equip-link">Сравнить технологии →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="about-team">
    <div class="container">
      <h2 data-reveal>Наши специалисты</h2>
      <p class="section-desc" data-reveal data-reveal-delay="1">
        7 сертифицированных мастеров лазерной эпиляции. Каждый прошёл обучение и имеет опыт
        работы на аппаратах Candela и IN-MOTION не менее 3 лет.
      </p>
      <div class="team-qualities">
        {[
          { title: 'Сертификация', desc: 'Все специалисты имеют медицинское образование или сертификат специалиста по аппаратной косметологии.' },
          { title: 'Опыт', desc: 'Минимальный опыт работы с лазерным оборудованием — 3 года. Средний по команде — 5 лет.' },
          { title: 'Обучение', desc: 'Регулярное обучение: обновления протоколов, новые зоны и особые случаи кожи.' },
          { title: 'Консультация', desc: 'Перед каждым курсом — консультация: определение фототипа, подбор аппарата, режима и плана процедур.' },
        ].map(({ title, desc }, i) => (
          <div class="team-quality" data-reveal data-reveal-delay={String(i + 1)}>
            <h4>{title}</h4>
            <p>{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Clinics -->
  <section class="about-clinics">
    <div class="container">
      <h2 data-reveal>Наши адреса</h2>
      <div class="clinics-list">
        {CLINICS.map((clinic, i) => (
          <div class="clinic-row" data-reveal data-reveal-delay={String(i + 1)}>
            <div class="clinic-info">
              <h3>{clinic.name}</h3>
              <address>
                <p>{clinic.address}</p>
                <p class="metro">м. {clinic.metro}</p>
              </address>
              <div class="hours">
                <span>Пн–Пт: {clinic.workingHours.weekdays}</span>
                <span>Сб–Вс: {clinic.workingHours.weekends}</span>
              </div>
            </div>
            <div class="clinic-actions">
              <a href={`tel:${clinic.phone.replace(/\D/g, '')}`} class="clinic-phone">{clinic.phone}</a>
              <a href="/booking/" class="btn-primary">Записаться</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="about-values">
    <div class="container">
      <h2 data-reveal>Наши принципы</h2>
      <div class="values-grid">
        {[
          { title: 'Честность', desc: 'Не обещаем результата, которого нет. Если лазер в Вашем случае не даст эффекта — скажем об этом на консультации.' },
          { title: 'Безопасность', desc: 'Медицинская лицензия — не формальность. Это обязательства, стандарты и ответственность за каждую процедуру.' },
          { title: 'Специализация', desc: 'Только лазерная эпиляция. Не пытаемся быть всем сразу — делаем одно дело лучше всех.' },
          { title: 'Долгосрочный результат', desc: 'Курс, а не разовые процедуры. Мы заинтересованы в том, чтобы Вы больше не возвращались — это лучший отзыв.' },
        ].map(({ title, desc }, i) => (
          <div class="value-item" data-reveal data-reveal-delay={String(i + 1)}>
            <h4>{title}</h4>
            <p>{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="about-cta">
    <div class="container">
      <div class="cta-box">
        <div data-reveal>
          <h2>Первая консультация бесплатно</h2>
          <p>Специалист определит фототип кожи, подберёт аппарат и ответит на все вопросы.</p>
        </div>
        <a href="/booking/" class="btn-primary" data-reveal data-reveal-delay="2">Записаться онлайн</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding: 2.5rem 0 4rem;
    background: var(--color-bg-soft);
    border-bottom: 1px solid var(--color-border);
  }
  .about-hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) { .about-hero-inner { grid-template-columns: 1fr 1fr; } }

  .about-badge {
    display: inline-flex;
    padding: 0.3rem 0.875rem;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 100px;
    margin-bottom: 1rem;
    letter-spacing: 0.03em;
  }
  .about-hero-content h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 1.25rem;
  }
  .accent { color: var(--color-primary); }
  .about-hero-content > p {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
    max-width: 480px;
  }

  .about-hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .big-stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .big-stat strong {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .big-stat span {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* License */
  .about-license { padding: 3.5rem 0; }
  .license-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 1024px) { .license-grid { grid-template-columns: 3fr 2fr; } }

  .about-license h2 { margin: 0 0 1.25rem; }
  .about-license p { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.65; margin: 0 0 1rem; }
  .about-license p:last-of-type { margin-bottom: 1.5rem; }

  .license-detail { margin-top: 0.5rem; }
  .license-badge-block {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: color-mix(in srgb, var(--color-primary) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
    border-radius: var(--radius-lg);
  }
  .badge-icon {
    width: 48px;
    height: 48px;
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .license-badge-block strong { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); display: block; }
  .license-badge-block p { font-size: 0.8125rem; color: var(--color-text-muted); margin: 0.25rem 0 0; }

  .positioning-card {
    padding: 2rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    height: 100%;
  }
  .positioning-card h3 { font-size: 1.0625rem; font-weight: 700; margin: 0 0 1.25rem; }
  .positioning-card ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .positioning-card li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .positioning-card li::before {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
    margin-top: 0.45em;
  }

  /* Equipment */
  .about-equipment {
    padding: 3.5rem 0;
    background: var(--color-bg-soft);
    border-top: 1px solid var(--color-border);
  }
  .about-equipment h2 { margin: 0 0 0.75rem; }
  .section-desc { font-size: 1.0625rem; color: var(--color-text-muted); max-width: 600px; margin: 0 0 2.5rem; line-height: 1.6; }

  .equipment-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 1024px) { .equipment-grid { grid-template-columns: 1fr 1fr; } }

  .equipment-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }
  .equipment-card--primary {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 10%, transparent);
  }
  .equip-header {
    padding: 1.75rem 2rem;
    background: var(--color-primary);
    color: #fff;
  }
  .equip-header--alt { background: var(--color-bg-dark); }
  .equip-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0.5rem;
  }
  .equip-header h3 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.375rem;
    line-height: 1.2;
  }
  .equip-type { font-size: 0.875rem; color: rgba(255,255,255,0.75); }
  .equip-body { padding: 2rem; }
  .equip-body p { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.65; margin: 0 0 1.25rem; }
  .equip-body ul { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .equip-body li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
  }
  .equip-body li::before {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
    margin-top: 0.4em;
  }
  .equip-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  /* Team */
  .about-team { padding: 3.5rem 0; }
  .about-team h2 { margin: 0 0 0.75rem; }
  .team-qualities {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) { .team-qualities { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .team-qualities { grid-template-columns: repeat(4, 1fr); } }

  .team-quality {
    padding: 1.5rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .team-quality h4 { font-size: 1rem; font-weight: 700; margin: 0 0 0.625rem; }
  .team-quality p { font-size: 0.9375rem; color: var(--color-text-muted); margin: 0; line-height: 1.55; }

  /* Clinics */
  .about-clinics {
    padding: 3.5rem 0;
    background: var(--color-bg-soft);
    border-top: 1px solid var(--color-border);
  }
  .about-clinics h2 { margin: 0 0 2rem; }
  .clinics-list { display: flex; flex-direction: column; gap: 1px; }
  .clinic-row {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .clinic-row {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0;
    }
    .clinics-list { gap: 1rem; }
  }
  .clinic-info h3 { font-size: 1.1875rem; font-weight: 700; margin: 0 0 0.5rem; }
  .clinic-info address { font-style: normal; }
  .clinic-info address p { font-size: 0.9375rem; color: var(--color-text); margin: 0; }
  .clinic-info .metro { font-size: 0.875rem; color: var(--color-text-muted); margin-top: 0.2rem; }
  .hours { display: flex; flex-direction: column; gap: 0.2rem; margin-top: 0.625rem; }
  .hours span { font-size: 0.875rem; color: var(--color-text-muted); }
  .clinic-actions { display: flex; flex-direction: column; align-items: flex-start; gap: 0.75rem; flex-shrink: 0; }
  @media (min-width: 480px) { .clinic-actions { flex-direction: row; align-items: center; } }
  .clinic-phone { font-weight: 700; font-size: 1rem; color: var(--color-text); text-decoration: none; white-space: nowrap; }
  .clinic-phone:hover { color: var(--color-primary); }

  /* Values */
  .about-values { padding: 3.5rem 0; }
  .about-values h2 { margin: 0 0 2rem; }
  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) { .values-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .values-grid { grid-template-columns: repeat(4, 1fr); } }

  .value-item {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--color-primary);
  }
  .value-item h4 { font-size: 1rem; font-weight: 700; margin: 0 0 0.625rem; }
  .value-item p { font-size: 0.9375rem; color: var(--color-text-muted); margin: 0; line-height: 1.55; }

  /* CTA */
  .about-cta {
    padding: 3.5rem 0 4.5rem;
    background: var(--color-bg-soft);
    border-top: 1px solid var(--color-border);
  }
  .cta-box {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) { .cta-box { flex-direction: row; align-items: center; justify-content: space-between; } }
  .cta-box h2 { font-size: clamp(1.25rem, 2.5vw, 1.625rem); margin: 0 0 0.5rem; }
  .cta-box p { font-size: 0.9375rem; color: var(--color-text-muted); margin: 0; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--color-primary);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background var(--transition-fast);
  }
  .btn-primary:hover { background: var(--color-primary-hover); color: #fff; }
</style>
