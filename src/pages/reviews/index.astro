---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaBreadcrumbs from '../../components/seo/SchemaBreadcrumbs.astro';

const allReviews = await getCollection('reviews');
const sorted = allReviews.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const sourceLabels: Record<string, string> = {
  internal: 'Laser Plus',
  yandex: 'Яндекс Карты',
  '2gis': '2ГИС',
};
---

<BaseLayout
  title="Отзывы клиентов о лазерной эпиляции — Laser Plus Новосибирск"
  description="Отзывы клиентов клиники лазерной эпиляции Laser Plus в Новосибирске. Реальные истории и результаты. Яндекс Карты, 2ГИС, отзывы на сайте."
>
  <div class="container">
    <SchemaBreadcrumbs items={[{ name: 'Отзывы', href: '/reviews/' }]} />
  </div>

  <section class="reviews-hero">
    <div class="container">
      <div class="hero-inner">
        <div>
          <h1 data-reveal>Отзывы клиентов</h1>
          <p class="hero-desc" data-reveal data-reveal-delay="1">
            Реальные истории клиентов Laser Plus. Нам важно, чтобы результат говорил сам за себя.
          </p>
        </div>
        <div class="rating-summary" data-reveal data-reveal-delay="2">
          <div class="rating-number">4.9</div>
          <div class="rating-info">
            <div class="stars" aria-label="Рейтинг 5 из 5">
              {'★★★★★'}
            </div>
            <p>{allReviews.length > 0 ? `${allReviews.length} отзывов` : 'Отзывы клиентов'}</p>
            <p class="rating-sources">Яндекс · 2ГИС · сайт</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="reviews-content">
    <div class="container">
      {sorted.length > 0 ? (
        <div class="reviews-grid">
          {sorted.map((review, i) => (
            <article class="review-card" data-reveal data-reveal-delay={String(Math.min((i % 3) + 1, 5))}>
              <div class="review-header">
                <div class="review-avatar" aria-hidden="true">
                  {review.data.name.charAt(0)}
                </div>
                <div class="review-meta">
                  <strong class="review-name">{review.data.name}</strong>
                  <div class="review-sub">
                    <span class="review-stars" aria-label={`Оценка ${review.data.rating} из 5`}>
                      {'★'.repeat(review.data.rating)}{'☆'.repeat(5 - review.data.rating)}
                    </span>
                    <span class="review-source">
                      {sourceLabels[review.data.source] ?? review.data.source}
                    </span>
                  </div>
                </div>
                <time class="review-date" datetime={review.data.date}>
                  {new Date(review.data.date).toLocaleDateString('ru-RU', {
                    month: 'long',
                    year: 'numeric',
                  })}
                </time>
              </div>
              <p class="review-text">{review.data.text}</p>
            </article>
          ))}
        </div>
      ) : (
        <p class="empty">Отзывы скоро появятся</p>
      )}
    </div>
  </section>

  <!-- External links -->
  <section class="reviews-external">
    <div class="container">
      <h2 data-reveal>Мы также на картах</h2>
      <p class="ext-desc" data-reveal data-reveal-delay="1">Читайте независимые отзывы на картографических сервисах.</p>
      <div class="ext-grid">
        <div class="ext-card" data-reveal data-reveal-delay="2">
          <strong>Яндекс Карты</strong>
          <p>Клиника на Красном Проспекте 94</p>
        </div>
        <div class="ext-card" data-reveal data-reveal-delay="3">
          <strong>2ГИС</strong>
          <p>Обе клиники — найдите «Laser Plus Новосибирск»</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="reviews-cta">
    <div class="container">
      <div class="cta-box">
        <div data-reveal>
          <h2>Убедитесь сами</h2>
          <p>Запишитесь на первую процедуру и составьте собственное мнение.</p>
        </div>
        <a href="/booking/" class="btn-primary" data-reveal data-reveal-delay="2">Записаться онлайн</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reviews-hero {
    padding: 2.5rem 0 3rem;
    background: var(--color-bg-soft);
    border-bottom: 1px solid var(--color-border);
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .hero-inner { flex-direction: row; align-items: center; justify-content: space-between; }
  }
  .reviews-hero h1 { margin: 0 0 0.75rem; }
  .hero-desc { font-size: 1.0625rem; color: var(--color-text-muted); margin: 0; max-width: 500px; line-height: 1.6; }

  .rating-summary {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-shrink: 0;
    padding: 1.5rem 2rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }
  .rating-number {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .rating-info { display: flex; flex-direction: column; gap: 0.25rem; }
  .stars { font-size: 1.25rem; color: #F59E0B; letter-spacing: 0.05em; }
  .rating-info p { font-size: 0.875rem; color: var(--color-text-muted); margin: 0; }
  .rating-sources { font-size: 0.8125rem; }

  /* Reviews grid */
  .reviews-content { padding: 3.5rem 0; }
  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) { .reviews-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1280px) { .reviews-grid { grid-template-columns: repeat(3, 1fr); } }

  .review-card {
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .review-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .review-avatar {
    width: 42px;
    height: 42px;
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .review-meta { flex: 1; min-width: 0; }
  .review-name { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); display: block; }
  .review-sub { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.25rem; }
  .review-stars { font-size: 0.875rem; color: #F59E0B; letter-spacing: 0.05em; }
  .review-source {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    padding: 0.1rem 0.5rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 100px;
  }
  .review-date { font-size: 0.8125rem; color: var(--color-text-muted); flex-shrink: 0; white-space: nowrap; }
  .review-text { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.65; margin: 0; }

  .empty { text-align: center; padding: 3rem; color: var(--color-text-muted); }

  /* External */
  .reviews-external { padding: 3.5rem 0; background: var(--color-bg-soft); border-top: 1px solid var(--color-border); }
  .reviews-external h2 { margin: 0 0 0.75rem; }
  .ext-desc { font-size: 1rem; color: var(--color-text-muted); margin: 0 0 2rem; }
  .ext-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 640px) { .ext-grid { grid-template-columns: 1fr 1fr; } }
  .ext-card {
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .ext-card strong { font-size: 1rem; font-weight: 700; display: block; margin-bottom: 0.375rem; }
  .ext-card p { font-size: 0.875rem; color: var(--color-text-muted); margin: 0; }

  /* CTA */
  .reviews-cta { padding: 3.5rem 0 4.5rem; background: var(--color-bg-soft); border-top: 1px solid var(--color-border); }
  .cta-box {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) { .cta-box { flex-direction: row; align-items: center; justify-content: space-between; } }
  .cta-box h2 { font-size: clamp(1.25rem, 2.5vw, 1.625rem); margin: 0 0 0.5rem; }
  .cta-box p { font-size: 0.9375rem; color: var(--color-text-muted); margin: 0; }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--color-primary);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background var(--transition-fast);
  }
  .btn-primary:hover { background: var(--color-primary-hover); color: #fff; }
</style>
