---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaBreadcrumbs from '../../components/seo/SchemaBreadcrumbs.astro';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['Все', 'Акции', 'До сеанса', 'После сеанса', 'Уход', 'FAQ'];

const fmt = (d: Date) => d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title="Блог — Laser Plus"
  description="Полезные статьи о лазерной эпиляции: подготовка к процедуре, уход после сеанса, акции и советы специалистов клиники Laser Plus в Новосибирске."
>
  <div class="container">
    <SchemaBreadcrumbs items={[{ name: 'Блог', href: '/blog/' }]} />
  </div>

  <section class="blog-hero">
    <svg class="blog-waves" viewBox="0 0 1200 400" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
      <path d="M -50 80 Q 200 20 500 120 Q 750 200 1000 100 Q 1150 50 1280 120" stroke="var(--color-primary)" stroke-opacity="0.07" stroke-width="10" stroke-linecap="round" fill="none"/>
      <path d="M -50 320 Q 250 260 580 340 Q 820 400 1060 310 Q 1180 270 1280 340" stroke="var(--color-primary)" stroke-opacity="0.1" stroke-width="10" stroke-linecap="round" fill="none"/>
    </svg>
    <div class="container">
      <p class="section-label">Полезные материалы</p>
      <h1 data-reveal>Блог</h1>
    </div>
  </section>

  <section class="blog-section">
    <div class="container">

      <!-- Табы-фильтры -->
      <div class="blog-tabs" role="tablist">
        {categories.map((cat) => (
          <button
            class={`blog-tab${cat === 'Все' ? ' blog-tab--active' : ''}`}
            data-category={cat}
            role="tab"
          >{cat}</button>
        ))}
      </div>

      <!-- Сетка статей -->
      <div class="blog-grid" id="blog-grid">
        {sorted.map((post) => (
          <article class="blog-card" data-category={post.data.category}>
            <div class="blog-card-body">
              <span class="blog-cat-badge">{post.data.category}</span>
              <h2 class="blog-card-title">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h2>
              <p class="blog-card-excerpt">{post.data.excerpt}</p>
            </div>
            <div class="blog-card-footer">
              <time class="blog-date" datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
              <a href={`/blog/${post.id}/`} class="blog-read-link">Читать →</a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.blog-tab');
  const cards = document.querySelectorAll<HTMLElement>('.blog-card');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const cat = tab.dataset.category!;

      tabs.forEach(t => t.classList.remove('blog-tab--active'));
      tab.classList.add('blog-tab--active');

      cards.forEach(card => {
        const match = cat === 'Все' || card.dataset.category === cat;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>

<style>
  .blog-hero {
    padding: 2rem 0 3rem;
    background: var(--color-bg-soft);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }
  .blog-waves {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .blog-hero .container { position: relative; }
  .blog-hero h1 { font-size: clamp(1.75rem, 3.5vw, 2.75rem); margin: 0.5rem 0 0; }

  .blog-section { padding: 2.5rem 0 5rem; }

  /* Табы */
  .blog-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }
  .blog-tab {
    padding: 0.5rem 1.25rem;
    border: 1.5px solid var(--color-border);
    border-radius: 100px;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
    font-family: var(--font-sans);
  }
  .blog-tab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .blog-tab--active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-bg-dark);
  }

  /* Сетка */
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) { .blog-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .blog-grid { grid-template-columns: 1fr 1fr 1fr; } }

  /* Карточка */
  .blog-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: box-shadow var(--transition-base), border-color var(--transition-base);
  }
  .blog-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }
  .blog-card-body {
    padding: 1.75rem 1.75rem 1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .blog-cat-badge {
    display: inline-flex;
    align-self: flex-start;
    padding: 0.2rem 0.75rem;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 100px;
    letter-spacing: 0.02em;
  }
  .blog-card-title {
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
  }
  .blog-card-title a {
    color: var(--color-text);
    text-decoration: none;
  }
  .blog-card-title a:hover { color: var(--color-primary); }
  .blog-card-excerpt {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }
  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.75rem 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .blog-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .blog-read-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }
  .blog-read-link:hover { text-decoration: underline; }
</style>
