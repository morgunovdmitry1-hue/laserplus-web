---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaBreadcrumbs from '../components/seo/SchemaBreadcrumbs.astro';
import { CLINICS, SITE } from '../consts';

const params = Astro.url.searchParams;
const prefilledService = params.get('service') ?? '';
const prefilledClinic = params.get('clinic') ?? '';

const yclientsId = import.meta.env.PUBLIC_YCLIENTS_COMPANY_ID ?? '';
---

<BaseLayout
  title="Онлайн-запись"
  description="Запишитесь на лазерную эпиляцию в клинику Laser Plus онлайн. Выберите услугу, клинику и удобное время."
>
  <div class="container">
    <SchemaBreadcrumbs items={[{ name: 'Запись онлайн', href: '/booking/' }]} />
  </div>

  <section class="booking-page">
    <div class="container">
      <div class="booking-inner">
        <div class="booking-info">
          <h1 data-reveal>Запись онлайн</h1>
          <p data-reveal data-reveal-delay="1">
            Выберите клинику, услугу и удобное время. Запись подтверждается в течение нескольких секунд.
          </p>
          <div class="booking-benefits">
            <div class="benefit" data-reveal data-reveal-delay="2">
              <strong>Без звонков</strong>
              <span>Запись в 2 клика, 24/7</span>
            </div>
            <div class="benefit" data-reveal data-reveal-delay="3">
              <strong>Бесплатная консультация</strong>
              <span>Ответим на любые вопросы</span>
            </div>
            <div class="benefit" data-reveal data-reveal-delay="4">
              <strong>Гибкая отмена</strong>
              <span>Перенос записи в любое время</span>
            </div>
          </div>
          <div class="booking-clinics">
            <p class="clinics-label">Выберите клинику:</p>
            {CLINICS.map((clinic) => (
              <a
                href={`/contacts/${clinic.id}/`}
                class:list={['clinic-option', { 'clinic-option--selected': prefilledClinic === clinic.id }]}
              >
                <strong>{clinic.name}</strong>
                <span>{clinic.address}</span>
                <span class="hours">{clinic.workingHours.weekdays}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- YClients widget -->
        <div class="widget-container" id="yclients-widget-container">
          {yclientsId ? (
            <div id="yclients-widget" class="widget-frame" />
          ) : (
            <div class="widget-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              <p>Загрузка формы записи…</p>
              <p class="widget-note">Укажите <code>PUBLIC_YCLIENTS_COMPANY_ID</code> в <code>.env</code> для подключения виджета</p>
            </div>
          )}
        </div>
      </div>

      <p class="booking-contact">
        Предпочитаете звонок? <a href={'tel:' + SITE.phone.replace(/\D/g, '')}>{SITE.phone}</a>
      </p>
    </div>
  </section>
</BaseLayout>

{yclientsId && (
  <script slot="scripts" is:inline define:vars={{ companyId: yclientsId }}>
    (function() {
      var script = document.createElement('script');
      script.src = 'https://api.yclients.com/api/v1/widget/loader.js';
      script.async = true;
      script.onload = function() {
        if (typeof YClientsWidget !== 'undefined') {
          new YClientsWidget({
            company_id: companyId,
            container: '#yclients-widget',
          });
        }
      };
      document.head.appendChild(script);
    })();
  </script>
)}

<style>
  .booking-page { padding: 1rem 0 4rem; }
  .booking-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .booking-inner { grid-template-columns: 1fr 1fr; }
  }

  .booking-info h1 { margin: 0 0 1rem; }
  .booking-info > p { font-size: 1.0625rem; color: var(--color-text-muted); margin: 0 0 2rem; line-height: 1.65; }

  .booking-benefits { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2.5rem; }
  .benefit { display: flex; flex-direction: column; gap: 0.2rem; }
  .benefit strong { font-size: 0.9375rem; font-weight: 700; }
  .benefit span { font-size: 0.875rem; color: var(--color-text-muted); }

  .clinics-label { font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-text-muted); margin: 0 0 0.75rem; }
  .booking-clinics { display: flex; flex-direction: column; gap: 0.75rem; }
  .clinic-option {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 1.25rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }
  .clinic-option:hover { border-color: var(--color-primary); background: color-mix(in srgb, var(--color-primary) 4%, transparent); }
  .clinic-option--selected { border-color: var(--color-primary); background: color-mix(in srgb, var(--color-primary) 6%, transparent); }
  .clinic-option strong { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); }
  .clinic-option span { font-size: 0.875rem; color: var(--color-text-muted); }
  .clinic-option .hours { font-size: 0.8125rem; }

  .widget-container {
    position: sticky;
    top: 80px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    min-height: 500px;
    overflow: hidden;
  }
  .widget-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 500px;
    gap: 1rem;
    color: var(--color-text-muted);
    padding: 2rem;
    text-align: center;
  }
  .widget-placeholder svg { opacity: 0.4; }
  .widget-placeholder p { margin: 0; font-size: 1rem; }
  .widget-note { font-size: 0.8125rem; opacity: 0.7; }

  .booking-contact {
    margin-top: 2.5rem;
    font-size: 1rem;
    color: var(--color-text-muted);
    text-align: center;
  }
  .booking-contact a { font-weight: 700; color: var(--color-primary); text-decoration: none; }
</style>
