---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaBreadcrumbs from '../../components/seo/SchemaBreadcrumbs.astro';

const clinics = await getCollection('clinics');
---

<BaseLayout
  title="Контакты и адреса клиник"
  description="Адреса клиник Laser Plus в Новосибирске. Красный Проспект, 94 и ул. Октябрьская. Телефоны, режим работы, как добраться."
>
  <div class="container">
    <SchemaBreadcrumbs items={[{ name: 'Контакты', href: '/contacts/' }]} />
  </div>

  <section class="contacts-page">
    <div class="container">
      <h1 data-reveal>Наши клиники</h1>
      <div class="clinics-grid">
        {clinics.map((clinic, i) => (
          <div class="clinic-card" data-reveal data-reveal-delay={String(i + 1)}>
            <h2><a href={`/contacts/${clinic.id}/`}>{clinic.data.name}</a></h2>
            <address>
              <p>{clinic.data.address}, {clinic.data.city}</p>
              {clinic.data.metro && <p>м. {clinic.data.metro}</p>}
            </address>
            <div class="hours">
              <p>Пн–Пт: {clinic.data.workingHours.weekdays}</p>
              <p>Сб–Вс: {clinic.data.workingHours.weekends}</p>
            </div>
            <a href={'tel:' + clinic.data.phone.replace(/\D/g, '')} class="phone-link">
              {clinic.data.phone}
            </a>
            <div class="card-actions">
              <a href={`/contacts/${clinic.id}/`} class="btn-secondary">Подробнее</a>
              <a href={`/booking/?clinic=${clinic.id}`} class="btn-primary">Записаться</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contacts-page { padding: 1rem 0 4rem; }
  .contacts-page h1 { margin-bottom: 2rem; }
  .clinics-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) { .clinics-grid { grid-template-columns: 1fr 1fr; } }

  .clinic-card {
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .clinic-card h2 { font-size: 1.375rem; margin: 0; }
  .clinic-card h2 a { color: var(--color-text); text-decoration: none; }
  .clinic-card h2 a:hover { color: var(--color-primary); }
  .clinic-card address { font-style: normal; color: var(--color-text-muted); font-size: 0.9375rem; }
  .clinic-card address p { margin: 0; }
  .hours { display: flex; flex-direction: column; gap: 0.25rem; }
  .hours p { font-size: 0.875rem; color: var(--color-text-muted); margin: 0; }
  .phone-link { font-weight: 700; font-size: 1.0625rem; color: var(--color-text); text-decoration: none; }
  .phone-link:hover { color: var(--color-primary); }
  .card-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
  }
  .btn-primary { background: var(--color-primary); color: var(--color-text-inverse); }
  .btn-primary:hover { background: var(--color-primary-hover); color: var(--color-text-inverse); }
  .btn-secondary { border: 1.5px solid var(--color-border-strong); color: var(--color-text); }
  .btn-secondary:hover { border-color: var(--color-primary); color: var(--color-primary); }
</style>
