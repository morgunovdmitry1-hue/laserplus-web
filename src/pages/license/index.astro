---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaBreadcrumbs from '../../components/seo/SchemaBreadcrumbs.astro';

const clinics = [
  {
    id: 'krasny-prospekt',
    name: 'Красный Проспект, 94',
    docs: [
      {
        title: 'Медицинская лицензия',
        file: '/docs/kp-license.pdf',
        icon: 'license',
      },
      {
        title: 'Санитарно-эпидемиологическое заключение',
        short: 'СЭЗ',
        file: '/docs/kp-sez.pdf',
        icon: 'sez',
      },
      {
        title: 'Регистрационное удостоверение на оборудование',
        short: 'РУ на оборудование',
        file: '/docs/kp-ru.pdf',
        icon: 'ru',
      },
    ],
  },
  {
    id: 'oktyabrskaya',
    name: 'Сакко и Ванцетти, 25/1',
    docs: [
      {
        title: 'Медицинская лицензия',
        file: '/docs/ok-license.pdf',
        icon: 'license',
      },
      {
        title: 'Санитарно-эпидемиологическое заключение',
        short: 'СЭЗ',
        file: '/docs/ok-sez.pdf',
        icon: 'sez',
      },
      {
        title: 'Регистрационное удостоверение на оборудование',
        short: 'РУ на оборудование',
        file: '/docs/ok-ru.pdf',
        icon: 'ru',
      },
    ],
  },
];
---

<BaseLayout
  title="Лицензии и документы — Laser Plus"
  description="Медицинские лицензии, санитарно-эпидемиологические заключения и регистрационные удостоверения клиник Laser Plus в Новосибирске."
>
  <div class="container">
    <SchemaBreadcrumbs items={[{ name: 'Лицензия', href: '/license/' }]} />
  </div>

  <section class="license-page">
    <div class="container">
      <div class="license-header" data-reveal>
        <p class="section-label">Документы</p>
        <h1>Лицензии и разрешительная документация</h1>
        <p class="license-lead">Laser Plus работает на основании медицинской лицензии. Все документы находятся в открытом доступе.</p>
      </div>

      <div class="clinics-docs">
        {clinics.map((clinic, i) => (
          <div class="clinic-docs-block" data-reveal data-reveal-delay={String(i + 1)}>
            <div class="clinic-docs-header">
              <div class="clinic-docs-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                  <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
              </div>
              <h2>{clinic.name}</h2>
            </div>

            <div class="docs-list">
              {clinic.docs.map((doc) => (
                <a
                  href={doc.file}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="doc-card"
                  aria-label={doc.title}
                >
                  <div class="doc-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                      <polyline points="14 2 14 8 20 8"/>
                      <line x1="16" y1="13" x2="8" y2="13"/>
                      <line x1="16" y1="17" x2="8" y2="17"/>
                      <polyline points="10 9 9 9 8 9"/>
                    </svg>
                  </div>
                  <div class="doc-info">
                    <span class="doc-label">{doc.short ?? doc.title}</span>
                    <span class="doc-full-title">{doc.title}</span>
                  </div>
                  <div class="doc-arrow">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                      <polyline points="7 10 12 15 17 10"/>
                      <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                    <span>Открыть</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .license-page {
    padding: 1rem 0 5rem;
  }

  .license-header {
    margin-bottom: 3rem;
  }
  .license-header h1 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0.5rem 0 1rem;
  }
  .license-lead {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    max-width: 560px;
    margin: 0;
  }

  .clinics-docs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 900px) {
    .clinics-docs {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }

  .clinic-docs-block {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .clinic-docs-header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-soft);
    border-bottom: 1px solid var(--color-border);
  }
  .clinic-docs-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .clinic-docs-header h2 {
    font-size: 1.0625rem;
    font-weight: 700;
    margin: 0;
  }

  .docs-list {
    display: flex;
    flex-direction: column;
  }

  .doc-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.125rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--transition-fast);
  }
  .doc-card:last-child { border-bottom: none; }
  .doc-card:hover {
    background: color-mix(in srgb, var(--color-primary) 4%, transparent);
  }

  .doc-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .doc-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
    min-width: 0;
  }
  .doc-label {
    font-weight: 700;
    font-size: 0.9375rem;
  }
  .doc-full-title {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .doc-arrow {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-primary);
    font-size: 0.8125rem;
    font-weight: 600;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }
  .doc-card:hover .doc-arrow { opacity: 1; }
</style>
