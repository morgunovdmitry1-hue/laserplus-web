---
import { SITE, CLINICS, SOCIAL, NAV_LINKS } from '../../consts';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label={SITE.name + ' — на главную'}>
          <span class="footer-logo-icon">
            <img src="/logo-icon.svg" alt="" width="32" height="32" />
          </span>
          <span class="footer-logo-name">
            <span>Laser</span><span class="accent">Plus</span>
          </span>
        </a>
        <p class="footer-tagline">
          Медицинская клиника лазерной эпиляции.<br />
          Александритовый лазер Candela GentlePro.
        </p>
        <div class="footer-social">
          <a href={SOCIAL.vk} target="_blank" rel="noopener noreferrer" aria-label="ВКонтакте">
            <svg width="20" height="20" viewBox="0 0 90 90" fill="currentColor" aria-hidden="true">
              <path d="M87.935 21.894c0.626-2.086 0-3.619-2.977-3.619h-9.846c-2.504 0-3.658 1.324-4.283 2.785 0 0-5.008 12.204-12.101 20.132-2.294 2.295-3.337 3.026-4.59 3.026-0.625 0-1.531-0.731-1.531-2.816V21.894c0-2.503-0.727-3.619-2.813-3.619H34.32c-1.564 0-2.506 1.162-2.506 2.264 0 2.373 3.547 2.921 3.913 9.597v14.499c0 3.179-0.574 3.757-1.826 3.757-3.337 0-11.457-12.26-16.273-26.288-0.944-2.727-1.89-3.828-4.406-3.828H3.376C0.562 18.275 0 19.599 0 21.059c0 2.608 3.337 15.543 15.542 32.65 8.136 11.682 19.599 18.016 30.031 18.016 6.258 0 7.033-1.407 7.033-3.83v-8.829c0-2.814 0.593-3.375 2.575-3.375 1.46 0 3.963 0.729 9.805 6.362 6.676 6.676 7.776 9.671 11.532 9.671h9.846c2.812 0 4.219-1.407 3.408-4.182-0.889-2.767-4.076-6.781-8.305-11.538-2.295-2.712-5.738-5.633-6.781-7.094-1.461-1.877-1.043-2.711 0-4.381C74.687 44.53 86.684 27.631 87.935 21.894"/>
            </svg>
          </a>
          <a href={SOCIAL.telegram} target="_blank" rel="noopener noreferrer" aria-label="Telegram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.19 13.36 4.23 12.4c-.658-.204-.671-.658.136-.975l11.57-4.461c.548-.196 1.027.134.858.958z"/>
            </svg>
          </a>
          <a href={SOCIAL.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <a href={SOCIAL.max} target="_blank" rel="noopener noreferrer" aria-label="MAX">
            <svg width="18" height="18" viewBox="0 0 720 720" fill="currentColor" aria-hidden="true">
              <path d="M350.4,9.6C141.8,20.5,4.1,184.1,12.8,390.4c3.8,90.3,40.1,168,48.7,253.7,2.2,22.2-4.2,49.6,21.4,59.3,31.5,11.9,79.8-8.1,106.2-26.4,9-6.1,17.6-13.2,24.2-22,27.3,18.1,53.2,35.6,85.7,43.4,143.1,34.3,299.9-44.2,369.6-170.3C799.6,291.2,622.5-4.6,350.4,9.6h0ZM269.4,504c-11.3,8.8-22.2,20.8-34.7,27.7-18.1,9.7-23.7-.4-30.5-16.4-21.4-50.9-24-137.6-11.5-190.9,16.8-72.5,72.9-136.3,150-143.1,78-6.9,150.4,32.7,183.1,104.2,72.4,159.1-112.9,316.2-256.4,218.6h0Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <nav aria-label="Навигация в подвале">
        <h3 class="footer-heading">Разделы</h3>
        <ul class="footer-links">
          {NAV_LINKS.map(({ href, label }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Clinics -->
      <div>
        <h3 class="footer-heading">Клиники</h3>
        <div class="footer-clinics">
          {CLINICS.map((clinic) => (
            <div class="clinic-item">
              <a href={`/contacts/${clinic.id}/`} class="clinic-name">{clinic.name}</a>
              <p class="clinic-address">{clinic.address}</p>
              <a href={'tel:+' + clinic.phone.replace(/\D/g, '')} class="clinic-phone">
                {clinic.phone}
              </a>
              <p class="clinic-hours">
                {clinic.workingHours.weekdays === clinic.workingHours.weekends
                  ? `Ежедневно ${clinic.workingHours.weekdays}`
                  : `Пн–Пт ${clinic.workingHours.weekdays} / Сб–Вс ${clinic.workingHours.weekends}`
                }
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="footer-cta">
        <h3 class="footer-heading">Запишитесь онлайн</h3>
        <p>Выберите удобное время — запись занимает менее 2 минут.</p>
        <a href="/booking/" class="btn-booking-footer">Записаться</a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>&copy; {currentYear} {SITE.name}. Все права защищены.</p>
      <div class="footer-legal">
        <a href="/privacy/">Политика конфиденциальности</a>
        <a href="/license/">Лицензия</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-dark);
    padding-top: 4rem;
    padding-bottom: 2rem;
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 2fr 1.5fr;
      gap: 3rem;
    }
  }

  /* Logo */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .footer-logo-icon {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .footer-logo-icon img { width: 32px; height: 32px; object-fit: cover; }
  .footer-logo-name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .accent { color: var(--color-primary); }

  .footer-tagline {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: color-mix(in srgb, #fff 45%, transparent);
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  .footer-social {
    display: flex;
    gap: 0.625rem;
  }
  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: color-mix(in srgb, #fff 45%, transparent);
    border: 1px solid color-mix(in srgb, #fff 15%, transparent);
    border-radius: var(--radius-md);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }
  .footer-social a:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .footer-heading {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: color-mix(in srgb, #fff 35%, transparent);
    margin: 0 0 1rem;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .footer-links a {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: color-mix(in srgb, #fff 65%, transparent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer-links a:hover { color: #fff; }

  .footer-clinics { display: flex; flex-direction: column; gap: 1.75rem; }
  .clinic-item { display: flex; flex-direction: column; gap: 0.25rem; }
  .clinic-name {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9375rem;
    color: #fff;
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .clinic-name:hover { color: var(--color-primary); }
  .clinic-address {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: color-mix(in srgb, #fff 45%, transparent);
    margin: 0;
    line-height: 1.5;
  }
  .clinic-phone {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: color-mix(in srgb, #fff 85%, transparent);
    text-decoration: none;
    transition: color var(--transition-fast);
    margin-top: 0.25rem;
  }
  .clinic-phone:hover { color: var(--color-primary); }
  .clinic-hours {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: color-mix(in srgb, #fff 35%, transparent);
    margin: 0.125rem 0 0;
    line-height: 1.6;
  }

  .footer-cta p {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: color-mix(in srgb, #fff 50%, transparent);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }
  .btn-booking-footer {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.5rem;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background var(--transition-fast), box-shadow var(--transition-fast);
    box-shadow: var(--shadow-primary);
  }
  .btn-booking-footer:hover {
    background: var(--color-primary-hover);
    color: #fff;
  }

  /* Bottom bar */
  .footer-bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, #fff 10%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
  .footer-bottom p {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: color-mix(in srgb, #fff 25%, transparent);
    margin: 0;
  }
  .footer-legal { display: flex; gap: 1.5rem; }
  .footer-legal a {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: color-mix(in srgb, #fff 25%, transparent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer-legal a:hover { color: color-mix(in srgb, #fff 60%, transparent); }
</style>
