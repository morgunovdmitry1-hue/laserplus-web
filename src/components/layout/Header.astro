---
import { NAV_LINKS, SITE } from '../../consts';

const pathname = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="container">
    <div class="header-inner">
      <a href="#main-content" class="skip-link sr-only focus:not-sr-only">
        Перейти к содержимому
      </a>

      <!-- Logo -->
      <a href="/" class="logo" aria-label={SITE.name + ' — на главную'}>
        <span class="logo-icon" aria-hidden="true">
          <img src="/logo-icon.svg" alt="" width="36" height="36" />
        </span>
        <span class="logo-name">
          <span class="logo-laser">Laser</span><span class="logo-plus">Plus</span>
        </span>
      </a>

      <!-- Desktop Nav — pill cursor effect -->
      <nav class="nav-desktop" aria-label="Основная навигация">
        <div class="nav-pill" id="nav-pill">
          <span class="nav-cursor" id="nav-cursor" aria-hidden="true"></span>
          <ul>
            {
              NAV_LINKS.map(({ href, label }) => {
                const isActive = pathname === href || (href !== '/' && pathname.startsWith(href));
                return (
                  <li data-active={isActive ? 'true' : undefined}>
                    <a
                      href={href}
                      class:list={['nav-link', { 'nav-link--active': isActive }]}
                      aria-current={isActive ? 'page' : undefined}
                    >
                      {label}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </div>
      </nav>

      <!-- Actions -->
      <div class="header-actions">
        <a href={'tel:+' + SITE.phone.replace(/\D/g, '')} class="header-phone" aria-label="Позвонить">
          {SITE.phone}
        </a>
        <a href="/booking/" class="btn-booking">Записаться</a>

        <button
          class="burger"
          aria-label="Открыть меню"
          aria-expanded="false"
          aria-controls="mobile-menu"
          id="burger-btn"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <nav aria-label="Мобильная навигация">
    <ul>
      {
        NAV_LINKS.map(({ href, label }) => (
          <li>
            <a href={href} class="mobile-nav-link">
              {label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="mobile-actions">
      <a href={'tel:+' + SITE.phone.replace(/\D/g, '')} class="mobile-phone">{SITE.phone}</a>
      <a href="/booking/" class="btn-booking btn-booking--full">Записаться онлайн</a>
    </div>
  </nav>
</div>

<script>
  // ── Pill cursor effect ──
  const pill = document.getElementById('nav-pill');
  const cursor = document.getElementById('nav-cursor');

  function moveCursor(li: HTMLElement) {
    if (!cursor || !pill) return;
    cursor.style.left = li.offsetLeft + 'px';
    cursor.style.width = li.offsetWidth + 'px';
    cursor.style.opacity = '1';
  }

  if (pill && cursor) {
    const items = pill.querySelectorAll<HTMLElement>('li');

    function setLit(li: HTMLElement | null) {
      items.forEach((el) => el.removeAttribute('data-lit'));
      if (li) li.setAttribute('data-lit', '');
    }

    // Position cursor on active item initially
    const activeItem = pill.querySelector<HTMLElement>('li[data-active]');
    if (activeItem) {
      cursor.style.left = activeItem.offsetLeft + 'px';
      cursor.style.width = activeItem.offsetWidth + 'px';
      cursor.style.opacity = '1';
      setLit(activeItem);
    }

    items.forEach((li) => {
      li.addEventListener('mouseenter', () => {
        moveCursor(li);
        setLit(li);
      });
    });

    pill.addEventListener('mouseleave', () => {
      const active = pill.querySelector<HTMLElement>('li[data-active]');
      if (active) {
        moveCursor(active);
        setLit(active);
      } else {
        cursor.style.opacity = '0';
        setLit(null);
      }
    });
  }

  // ── Burger menu ──
  const btn = document.getElementById('burger-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isOpen));
    menu?.setAttribute('aria-hidden', String(isOpen));
    btn.classList.toggle('is-open', !isOpen);
    menu?.classList.toggle('is-open', !isOpen);
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      btn?.setAttribute('aria-expanded', 'false');
      menu?.setAttribute('aria-hidden', 'true');
      btn?.classList.remove('is-open');
      menu?.classList.remove('is-open');
      document.body.style.overflow = '';
    });
  });

  // ── Scroll shadow ──
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 8);
  }, { passive: true });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow var(--transition-base);
  }
  .site-header.is-scrolled {
    box-shadow: 0 2px 16px -4px rgb(17 32 48 / 0.12);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    height: 68px;
  }

  /* Logo */
  .logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
  }
  .logo-icon {
    display: flex;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
  }
  .logo-icon img { width: 36px; height: 36px; object-fit: cover; }
  .logo-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .logo-laser { color: var(--color-text); }
  .logo-plus  { color: var(--color-primary); }

  /* ── Desktop nav — pill cursor ── */
  .nav-desktop {
    display: none;
    flex: 1;
    justify-content: center;
  }
  @media (min-width: 1024px) {
    .nav-desktop { display: flex; }
  }

  .nav-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    border: 1.5px solid var(--color-border);
    border-radius: 100px;
    padding: 4px;
    background: #fff;
  }

  /* Animated cursor pill */
  .nav-cursor {
    position: absolute;
    top: 4px;
    left: 0;
    height: calc(100% - 8px);
    background: var(--color-primary);
    border-radius: 100px;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    box-shadow: var(--shadow-primary);
    transition:
      left 260ms cubic-bezier(0.4, 0, 0.2, 1),
      width 260ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 180ms ease;
  }

  .nav-pill ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    position: relative;
    z-index: 1;
    display: block;
    padding: 0.375rem 0.875rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    border-radius: 100px;
    user-select: none;
    transition: color 120ms ease;
  }
  /* Text turns white when pill is underneath */
  li[data-lit] .nav-link {
    color: #fff;
  }

  /* Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-left: auto;
  }
  .header-phone {
    display: none;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--transition-fast);
  }
  .header-phone:hover { color: var(--color-primary); }
  @media (min-width: 768px) { .header-phone { display: block; } }

  .btn-booking {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.375rem;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background var(--transition-fast), box-shadow var(--transition-fast);
    white-space: nowrap;
    box-shadow: var(--shadow-primary);
  }
  .btn-booking:hover {
    background: var(--color-primary-hover);
    color: #fff;
    box-shadow: 0 6px 20px -2px rgb(100 176 199 / 0.45);
  }
  .btn-booking--full {
    width: 100%;
    justify-content: center;
    padding: 1rem 1.5rem;
    font-size: 1rem;
    border-radius: var(--radius-md);
  }

  /* Burger */
  .burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: 1px solid var(--color-border);
    cursor: pointer;
    padding: 9px;
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast);
  }
  .burger:hover { border-color: var(--color-primary); }
  @media (min-width: 1024px) { .burger { display: none; } }
  .burger span {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-base), opacity var(--transition-base);
    transform-origin: center;
  }
  .burger.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .burger.is-open span:nth-child(2) { opacity: 0; }
  .burger.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    inset: 68px 0 0;
    background: var(--color-bg);
    z-index: 40;
    padding: 2rem var(--container-padding-mobile);
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform var(--transition-slow);
    border-top: 1px solid var(--color-border);
  }
  .mobile-menu.is-open { transform: translateX(0); }
  .mobile-menu ul { list-style: none; margin: 0; padding: 0; }
  .mobile-nav-link {
    display: block;
    padding: 1rem 0;
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-fast);
  }
  .mobile-nav-link:hover { color: var(--color-primary); }
  .mobile-actions {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .mobile-phone {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .mobile-phone:hover { color: var(--color-primary); }
</style>
